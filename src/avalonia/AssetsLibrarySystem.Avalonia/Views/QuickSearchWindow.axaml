<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AssetsLibrarySystem.Avalonia.ViewModels"
        xmlns:models="using:AssetsLibrarySystem.Avalonia.Models"
        xmlns:lucide="clr-namespace:Lucide.Avalonia;assembly=Lucide.Avalonia"
        x:Class="AssetsLibrarySystem.Avalonia.Views.QuickSearchWindow"
        x:DataType="vm:QuickSearchViewModel"
        Width="760"
        Height="460"
        CanResize="False"
        ShowInTaskbar="False"
        Topmost="True"
        WindowDecorations="None"
        Background="{DynamicResource AppWindowBackgroundBrush}"
        WindowStartupLocation="CenterScreen"
        Title="快速检索">

    <Window.Styles>
        <Style Selector="Border.popup-shell">
            <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="14" />
        </Style>
        <Style Selector="Border.popup-input-shell">
            <Setter Property="Background" Value="{DynamicResource AppSoftSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="10,8" />
        </Style>
        <Style Selector="Border.popup-result">
            <Setter Property="Background" Value="{DynamicResource AppSoftSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
        <Style Selector="Button.popup-icon">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="30" />
        </Style>
        <Style Selector="Button.popup-icon:pointerover">
            <Setter Property="Background" Value="{DynamicResource AppSoftSurfaceBrush}" />
        </Style>
        <Style Selector="TextBlock.popup-title">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
        </Style>
        <Style Selector="TextBlock.popup-hint">
            <Setter Property="Foreground" Value="{DynamicResource AppSecondaryTextBrush}" />
            <Setter Property="FontSize" Value="10" />
        </Style>
        <Style Selector="TextBox.popup-input">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="FontSize" Value="14" />
        </Style>
        <Style Selector="TextBox.popup-input:focus">
            <Setter Property="CaretBrush" Value="{DynamicResource AppAccentBrush}" />
        </Style>
    </Window.Styles>

    <Border Classes="popup-shell">
        <Grid RowDefinitions="Auto,Auto,*" RowSpacing="12">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <Border Classes="popup-input-shell">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                        <Border Width="24"
                                Height="24"
                                Background="{DynamicResource AppAccentSurfaceBrush}"
                                BorderBrush="{DynamicResource AppAccentBrush}"
                                BorderThickness="1"
                                CornerRadius="999"
                                VerticalAlignment="Center">
                            <lucide:LucideIcon HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Size="12"
                                               Kind="Search" />
                        </Border>
                        <TextBox x:Name="SearchTextBox"
                                 Grid.Column="1"
                                 Classes="popup-input"
                                 Text="{Binding SearchQuery, Mode=TwoWay}"
                                 KeyDown="SearchTextBox_KeyDown"
                                 PlaceholderText="输入素材描述并回车，例如：紧张氛围的音乐" />
                    </Grid>
                </Border>

                <Button Grid.Column="1"
                        Classes="popup-icon"
                        Click="CloseWindow_Click">
                    <lucide:LucideIcon Classes="shell-glyph" Kind="X" Size="12" />
                </Button>
            </Grid>

            <TextBlock Grid.Row="1"
                       Classes="popup-hint"
                       Text="{Binding SearchStatus}" />

            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding SearchResults}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:AssetSearchDocument">
                            <Border Classes="popup-result">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                    <StackPanel Spacing="2">
                                        <TextBlock Foreground="{DynamicResource AppTextBrush}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"
                                                   Text="{Binding AssetName}" />
                                        <TextBlock Classes="popup-hint" Text="{Binding AssetPath}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" HorizontalAlignment="Right" Spacing="2">
                                        <Border Background="{DynamicResource AppAccentSurfaceBrush}"
                                                BorderBrush="{DynamicResource AppAccentBrush}"
                                                BorderThickness="1"
                                                CornerRadius="999"
                                                Padding="8,3">
                                            <TextBlock Foreground="{DynamicResource AppAccentBrush}"
                                                       FontSize="10"
                                                       Text="{Binding RerankScore, StringFormat=rerank {0:0.0000}}" />
                                        </Border>
                                        <TextBlock Classes="popup-hint"
                                                   HorizontalAlignment="Right"
                                                   Text="{Binding AssetType}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
