<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AssetsLibrarySystem.Avalonia.ViewModels"
        xmlns:models="using:AssetsLibrarySystem.Avalonia.Models"
        xmlns:lucide="clr-namespace:Lucide.Avalonia;assembly=Lucide.Avalonia"
        x:Class="AssetsLibrarySystem.Avalonia.Views.QuickSearchWindow"
        x:DataType="vm:QuickSearchViewModel"

        CanResize="False"
        ShowInTaskbar="False"
        Topmost="True"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterScreen"
        Title="快速检索">

    <Window.Styles>
        <Style Selector="Window">
            <Setter Property="Background" Value="{x:Null}" />
            <Setter Property="WindowDecorations" Value="BorderOnly" />
            <Setter Property="ExtendClientAreaToDecorationsHint" Value="True" />
            <Setter Property="CanResize" Value="False" />
            <Setter Property="ShowInTaskbar" Value="False" />
            <Setter Property="Topmost" Value="True" />
        </Style>
    </Window.Styles>

    <Design.DataContext>
        <vm:QuickSearchViewModel SearchQuery="紧张氛围的音乐"
                                 SearchStatus="按 Enter 执行检索，方向键浏览历史。">
            <vm:QuickSearchViewModel.SearchResults>
                <models:AssetSearchDocument AssetId="asset-001"
                                            AssetName="37_zombie.mp3"
                                            AssetType="音频"
                                            AssetPath="D:\Data\全资源\music\邦多利背景音乐未整理\37_zombie.mp3"
                                            Description="节奏逐步推进、情绪偏压抑的音频片段。"
                                            SourceStorePath="D:\GitRepository\AssetsLibrarySystem\data\asset_descriptions.db"
                                            GeneratedAt="2026-06-01T18:00:00+08:00"
                                            EmbeddingSimilarity="0.4818"
                                            RerankScore="9.6875" />
                <models:AssetSearchDocument AssetId="asset-002"
                                            AssetName="opening_theme.wav"
                                            AssetType="音频"
                                            AssetPath="D:\Data\全资源\music\DDLC\DDLC_PLUS\opening_theme.wav"
                                            Description="适合开场和菜单场景的氛围音乐。"
                                            SourceStorePath="D:\GitRepository\AssetsLibrarySystem\data\asset_descriptions.db"
                                            GeneratedAt="2026-06-01T18:00:00+08:00"
                                            EmbeddingSimilarity="0.7602"
                                            RerankScore="8.2241" />
            </vm:QuickSearchViewModel.SearchResults>
        </vm:QuickSearchViewModel>
    </Design.DataContext>

    <Border MinWidth="720"
            Background="{DynamicResource SystemAltMediumHighColor}"
            Margin="8">
        <Grid RowDefinitions="Auto,*" RowSpacing="12">
            <Border Grid.Row="0"
                    Background="{DynamicResource SystemAltLowColor}"
                    Padding="12,10">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                        <lucide:LucideIcon HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Size="16"
                                           Kind="Search" />
                    <TextBox x:Name="SearchTextBox"
                             Grid.Column="1"
                             Text="{Binding SearchQuery, Mode=TwoWay}"
                             KeyDown="SearchTextBox_KeyDown"
                             Background="Transparent"
                             BorderBrush="Transparent"
                             Foreground="{DynamicResource AppTextBrush}"
                             FontFamily="Consolas"
                             VerticalContentAlignment="Center"
                             Padding="0,0,0,0"
                             PlaceholderText="输入素材描述并回车，例如：紧张氛围的音乐">
                        <TextBox.Styles>
                            <Style Selector="TextBox /template/ Border#PART_BorderElement">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderBrush" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                            </Style>
                            <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderBrush" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                            </Style>

                        </TextBox.Styles>
                    </TextBox>
                </Grid>
            </Border>

            <Grid Grid.Row="1" RowDefinitions="Auto,*" RowSpacing="10">
                <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                           FontSize="10"
                           Text="{Binding SearchStatus}" />

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding SearchResults}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:AssetSearchDocument">
                                <Border Background="{DynamicResource AppSoftSurfaceBrush}"
                                        BorderBrush="{DynamicResource AppBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="10"
                                        Margin="0,0,0,8">
                                    <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="6">
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                            <StackPanel Spacing="1">
                                                <TextBlock Foreground="{DynamicResource AppTextBrush}"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"
                                                           Text="{Binding AssetName}" />
                                                <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                                           FontSize="10"
                                                           Text="{Binding AssetType}" />
                                            </StackPanel>
                                            <Border Grid.Column="1" Background="{DynamicResource AppAccentSurfaceBrush}"
                                                    BorderBrush="{DynamicResource AppAccentBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="999"
                                                    Padding="8,3">
                                                <TextBlock Foreground="{DynamicResource AppAccentBrush}"
                                                           FontSize="10"
                                                           Text="{Binding RerankScore, StringFormat=rerank {0:0.0000}}" />
                                            </Border>
                                        </Grid>
                                        <TextBlock Grid.Row="1"
                                                   Foreground="{DynamicResource AppSecondaryTextBrush}"
                                                   FontSize="10"
                                                   TextTrimming="CharacterEllipsis"
                                                   Text="{Binding AssetPath}" />
                                        <TextBlock Grid.Row="2"
                                                   Foreground="{DynamicResource AppTextBrush}"
                                                   TextWrapping="Wrap"
                                                   Text="{Binding Description}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Border>
</Window>
