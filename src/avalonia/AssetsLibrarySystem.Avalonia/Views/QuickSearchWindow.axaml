<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AssetsLibrarySystem.Avalonia.ViewModels"
        xmlns:models="using:AssetsLibrarySystem.Application.Models"
        xmlns:lucide="clr-namespace:Lucide.Avalonia;assembly=Lucide.Avalonia"
        x:Class="AssetsLibrarySystem.Avalonia.Views.QuickSearchWindow"
        x:DataType="vm:QuickSearchViewModel"

        CanResize="False"
        ShowInTaskbar="False"
        Topmost="True"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterScreen"
        TransparencyLevelHint="AcrylicBlur"
        Background="Transparent"
        Title="快速检索">

    <Window.Styles>
        <Style Selector="Window">
            <Setter Property="Background" Value="{x:Null}" />
            <Setter Property="WindowDecorations" Value="BorderOnly" />
            <Setter Property="ExtendClientAreaToDecorationsHint" Value="True" />
            <Setter Property="CanResize" Value="False" />
            <Setter Property="ShowInTaskbar" Value="False" />
            <Setter Property="Topmost" Value="True" />
        </Style>
        <Style Selector="Button.search-result-card:pointerover">
            <Setter Property="Background" Value="#802B2B2B" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
        </Style>
        <Style Selector="Button.search-result-card:pressed">
            <Setter Property="Background" Value="#66242424" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
        </Style>
    </Window.Styles>

    <Design.DataContext>
        <vm:QuickSearchViewModel SearchQuery="紧张氛围的音乐"
                                 SearchAssetFormat="智能类型"
                                 SearchStatus="已返回 2 条素材。"
                                 SearchMetricsSummary="参数：候选 20，扩展候选 50，Top-K 5；类型：智能类型 / 音频；召回 20，重排 20，返回 2；耗时 382 ms，向量化 token 32，重排序 token 1248。">
            <vm:QuickSearchViewModel.SearchResults>
                <models:AssetSearchDocument AssetId="asset-001"
                                            AssetName="37_zombie.mp3"
                                            AssetType="音频"
                                            AssetPath="D:\Data\全资源\music\邦多利背景音乐未整理\37_zombie.mp3"
                                            Description="节奏逐步推进、情绪偏压抑的音频片段。"
                                            GeneratedAt="2026-06-01T18:00:00+08:00"
                                            EmbeddingSimilarity="0.4818"
                                            VectorDistance="0.5182"
                                            RerankScore="9.6875"
                                            CombinedScore="0.7825" />
                <models:AssetSearchDocument AssetId="asset-002"
                                            AssetName="opening_theme.wav"
                                            AssetType="音频"
                                            AssetPath="D:\Data\全资源\music\DDLC\DDLC_PLUS\opening_theme.wav"
                                            Description="适合开场和菜单场景的氛围音乐。"
                                            GeneratedAt="2026-06-01T18:00:00+08:00"
                                            EmbeddingSimilarity="0.7602"
                                            VectorDistance="0.2398"
                                            RerankScore="8.2241"
                                            CombinedScore="0.8116" />
            </vm:QuickSearchViewModel.SearchResults>
        </vm:QuickSearchViewModel>
    </Design.DataContext>

    <Border Width="760"
            MaxHeight="600"
            Padding="10,0,10,10"
            >
        <Border.Background>
            <SolidColorBrush Color="Black" Opacity="0.6"></SolidColorBrush>
        </Border.Background>
        <Grid RowDefinitions="10,Auto">
            <Panel Background="Transparent" WindowDecorationProperties.ElementRole="TitleBar"></Panel>
        <Grid Grid.Row="1" RowDefinitions="Auto,*" RowSpacing="10">
            <Border Grid.Row="0"
                    Background="#662B2B2B"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="14,10">
                <Grid ColumnDefinitions="Auto,*,120" ColumnSpacing="8">
                    <lucide:LucideIcon HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Size="16"
                                       Kind="Search" />
                    <TextBox x:Name="SearchTextBox"
                             Grid.Column="1"
                             Text="{Binding SearchQuery, Mode=TwoWay}"
                             KeyDown="SearchTextBox_KeyDown"
                             Background="Transparent"
                             BorderBrush="Transparent"
                             Foreground="{DynamicResource AppTextBrush}"
                             FontFamily="Noto Sans SC"
                             VerticalContentAlignment="Center"
                             Padding="0,0,0,0"
                             PlaceholderText="输入素材描述并回车，例如：紧张氛围的音乐">
                        <TextBox.Styles>
                            <Style Selector="TextBox /template/ Border#PART_BorderElement">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderBrush" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                            </Style>
                            <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderBrush" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                            </Style>
                            <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderBrush" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                            </Style>
                        </TextBox.Styles>
                    </TextBox>

                    <ComboBox Grid.Column="2"
                              SelectedItem="{Binding SearchAssetFormat, Mode=TwoWay}"
                              ItemsSource="{Binding SearchAssetFormats}"
                              Background="Transparent"
                              BorderBrush="Transparent"
                              Foreground="{DynamicResource AppTextBrush}"
                              VerticalContentAlignment="Center"
                              HorizontalContentAlignment="Stretch">
                        <ComboBox.Styles>
                            <Style Selector="ComboBox /template/ Border#PART_BorderElement">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderBrush" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                            </Style>
                            <Style Selector="ComboBox:focus /template/ Border#PART_BorderElement">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderBrush" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                            </Style>
                            <Style Selector="ComboBox:pointerover /template/ Border#PART_BorderElement">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderBrush" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                            </Style>
                        </ComboBox.Styles>
                    </ComboBox>
                </Grid>
            </Border>

            <Grid Grid.Row="1" RowDefinitions="Auto,Auto,*" RowSpacing="6">
                <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                           FontSize="10"
                           Text="{Binding SearchStatus}" />
                <TextBlock Grid.Row="1"
                           Foreground="{DynamicResource AppSecondaryTextBrush}"
                           FontSize="10"
                           TextWrapping="Wrap"
                           Text="{Binding SearchMetricsSummary}" />

                <ScrollViewer Grid.Row="2"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding SearchResults}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Spacing="8" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:AssetSearchDocument">
                                <Button
                                    Classes="search-result-card"
                                    Background="#662B2B2B"
                                    BorderBrush="{DynamicResource AppBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="10"
                                    HorizontalAlignment="Stretch"
                                    Click="RevealSearchResult_Click"
                                    CommandParameter="{Binding}"
                                    ToolTip.Tip="点击定位到文件资源管理器">

                                    <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="6">
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                            <StackPanel Spacing="1">
                                                <TextBlock Foreground="{DynamicResource AppTextBrush}"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"
                                                           Text="{Binding AssetName}" />
                                                <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                                           FontSize="10"
                                                           Text="{Binding AssetType}" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Spacing="1" HorizontalAlignment="Right">
                                                <TextBlock Foreground="{DynamicResource AppAccentBrush}"
                                                           FontSize="10"
                                                           Text="{Binding CombinedScore, StringFormat=combo {0:0.0000}}" />
                                                <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                                           FontSize="10"
                                                           Text="{Binding RerankScore, StringFormat=rerank {0:0.0000}}" />
                                            </StackPanel>
                                        </Grid>
                                        <TextBlock Grid.Row="1"
                                                   Foreground="{DynamicResource AppSecondaryTextBrush}"
                                                   FontSize="10"
                                                   TextTrimming="CharacterEllipsis"
                                                   Text="{Binding AssetPath}" />
                                        <Grid Grid.Row="2" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                            <TextBlock Foreground="{DynamicResource AppTextBrush}"
                                                       TextWrapping="Wrap"
                                                       FontSize="12"
                                                       Text="{Binding Description}" />
                                            <TextBlock Grid.Column="1"
                                                       Foreground="{DynamicResource AppSecondaryTextBrush}"
                                                       FontSize="10"
                                                       Text="{Binding VectorDistance, StringFormat=dist {0:0.0000}}" />
                                        </Grid>
                                        <ItemsControl Grid.Row="3"
                                                      ItemsSource="{Binding AngleTags}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="x:String">
                                                    <Border Margin="0,0,4,4"
                                                            Padding="6,2"
                                                            CornerRadius="4"
                                                            Background="#551F1F1F"
                                                            BorderBrush="{DynamicResource AppBorderBrush}"
                                                            BorderThickness="1">
                                                        <TextBlock MaxWidth="620"
                                                                   Foreground="{DynamicResource AppSecondaryTextBrush}"
                                                                   FontSize="10"
                                                                   TextWrapping="Wrap"
                                                                   Text="{Binding}" />
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>
        </Grid>

    </Border>
</Window>
