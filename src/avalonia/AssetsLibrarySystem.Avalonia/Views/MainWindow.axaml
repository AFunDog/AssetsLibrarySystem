<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AssetsLibrarySystem.Avalonia.ViewModels"
        xmlns:models="using:AssetsLibrarySystem.Application.Models"
        xmlns:pages="using:AssetsLibrarySystem.Avalonia.Views.Pages"
        mc:Ignorable="d"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        x:Class="AssetsLibrarySystem.Avalonia.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        d:DesignWidth="1440"
        d:DesignHeight="860"
        Icon="/Assets/avalonia-logo.ico"
        Title="Assets Library System"
        WindowDecorations="BorderOnly"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="30"
        Background="{DynamicResource AppWindowBackgroundBrush}"
        Foreground="{DynamicResource AppTextBrush}">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Border Margin="4">
        <Grid RowDefinitions="Auto,Auto,*" RowSpacing="8">
            <Border Background="Transparent"
                    BorderThickness="0"
                    CornerRadius="0"
                    Padding="0">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="4">
                    <Border WindowDecorationProperties.ElementRole="TitleBar"
                            Background="Transparent"
                            CornerRadius="0"
                            Padding="12">
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <Border Background="{DynamicResource AppAccentSurfaceBrush}"
                                    BorderBrush="{DynamicResource AppAccentBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="4">
                                <LucideIcon HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Margin="0"
                                            Kind="LibraryBig" />
                            </Border>
                            <StackPanel Spacing="1" VerticalAlignment="Center">
                                <TextBlock FontWeight="SemiBold"
                                           FontSize="20"
                                           Foreground="{DynamicResource AppTextBrush}"
                                           Text="Assets Library System" />
                                <Button Command="{Binding ToggleBackgroundTaskPanelCommand}"
                                        IsVisible="{Binding HasTitleBarTask}"
                                        Background="Transparent"
                                        BorderBrush="Transparent"
                                        BorderThickness="0"
                                        CornerRadius="4"
                                        Padding="0"
                                        HorizontalAlignment="Left">
                                    <Button.Styles>
                                        <Style Selector="Button:pointerover">
                                            <Setter Property="Background" Value="{DynamicResource AppSoftSurfaceBrush}" />
                                        </Style>
                                    </Button.Styles>
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <LucideIcon HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Kind="ListTodo"
                                                    Size="12" />
                                        <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                                   Text="{Binding TitleBarTaskText}"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <StackPanel.Styles>
                            <Style Selector="Button.window-control">
                                <Setter Property="Width" Value="24" />
                                <Setter Property="Height" Value="24" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderBrush" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="CornerRadius" Value="4" />
                                <Setter Property="Padding" Value="0" />
                            </Style>
                            <Style Selector="Button.window-control:pointerover">
                                <Setter Property="Background" Value="{DynamicResource AppSoftSurfaceBrush}" />
                            </Style>
                            <Style Selector="Button.window-control:pressed">
                                <Setter Property="Background" Value="{DynamicResource AppAccentSurfaceBrush}" />
                            </Style>
                        </StackPanel.Styles>

                        <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                            <Border Background="Transparent"
                                    BorderThickness="0"
                                    CornerRadius="0"
                                    Padding="0">
                                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">

                                    <LucideIcon HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Margin="0"
                                                Kind="Bot" />
                                    <StackPanel Spacing="1">
                                        <TextBlock FontWeight="SemiBold"
                                                   Text="{Binding BackendStatusTitle}" />
                                        <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                                   Text="{Binding BackendStatusStage}" />
                                        <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                                   Text="{Binding BackendEndpoint}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">

                                <LucideIcon HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Margin="0"
                                            Kind="Cpu" />

                                <StackPanel Spacing="1">
                                    <TextBlock FontWeight="SemiBold"
                                               Text="{Binding SearchModelStatusTitle}" />
                                    <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                               Text="{Binding SearchModelStatusStage}" />
                                    <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                               Text="{Binding SearchModelStatusDetail}"
                                               TextWrapping="NoWrap"
                                               TextTrimming="CharacterEllipsis"
                                               MaxWidth="280" />
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                            <Button WindowDecorationProperties.ElementRole="MinimizeButton"
                                    Classes="window-control"
                                    Click="MinimizeWindow_Click">
                                <LucideIcon HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Margin="0"
                                            Kind="Minus" />
                            </Button>
                            <Button WindowDecorationProperties.ElementRole="MaximizeButton"
                                    Classes="window-control"
                                    Click="ToggleMaximizeWindow_Click">
                                <LucideIcon HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Margin="0"
                                            Size="16"
                                            Kind="Square" />
                            </Button>
                            <Button WindowDecorationProperties.ElementRole="CloseButton"
                                    Classes="window-control"
                                    Click="CloseWindow_Click">
                                <LucideIcon HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Margin="0"
                                            Kind="X" />
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    IsVisible="{Binding IsBackgroundTaskPanelOpen}"
                    Background="{DynamicResource AppSurfaceBrush}"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12">
                <Grid RowDefinitions="Auto,*" RowSpacing="10">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <StackPanel Spacing="2">
                            <TextBlock FontWeight="SemiBold"
                                       Text="后台任务" />
                            <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                       Text="显示当前正在执行的任务，并保留最近完成或失败的记录。" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                Command="{Binding CloseBackgroundTaskPanelCommand}"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0"
                                Padding="4">
                            <LucideIcon HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Kind="X"
                                        Size="12" />
                        </Button>
                    </Grid>

                    <ScrollViewer Grid.Row="1"
                                  MaxHeight="260"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding BackgroundTasks}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:BackgroundTaskEntry">
                                    <Border Margin="0,0,0,8"
                                            Padding="10"
                                            Background="{DynamicResource AppSoftSurfaceBrush}"
                                            BorderBrush="{DynamicResource AppBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="6">
                                        <StackPanel Spacing="4">
                                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                <TextBlock FontWeight="SemiBold"
                                                           Text="{Binding Title}" />
                                                <Border Grid.Column="1"
                                                        Background="{DynamicResource AppAccentSurfaceBrush}"
                                                        BorderBrush="{DynamicResource AppAccentBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="4"
                                                        Padding="6,2">
                                                    <TextBlock FontSize="12"
                                                               Text="{Binding StatusText}" />
                                                </Border>
                                            </Grid>
                                            <TextBlock Text="{Binding StageText}" />
                                            <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                                       Text="{Binding DetailText}"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                                       FontSize="12"
                                                       Text="{Binding TimelineText}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <TabControl Grid.Row="2"
                        Classes="shell-tabs"
                        Background="Transparent"
                        TabStripPlacement="Left">
                <TabControl.Styles>
                    <Style Selector="TabControl.shell-tabs">
                        <Setter Property="Background" Value="Transparent" />
                    </Style>
                    <Style Selector="TabControl.shell-tabs > TabStrip">
                        <Setter Property="Width" Value="240" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="Padding" Value="0,4,0,0" />
                    </Style>
                    <Style Selector="TabControl.shell-tabs > ContentPresenter">
                        <Setter Property="Padding" Value="0" />
                    </Style>
                    <Style Selector="TabItem.nav-item">
                        <Setter Property="Foreground" Value="{DynamicResource AppMutedTextBrush}" />
                        <Setter Property="MinHeight" Value="44" />
                        <Setter Property="Padding" Value="8,6" />
                        <Setter Property="Margin" Value="0,0,0,4" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="VerticalContentAlignment" Value="Center" />
                    </Style>
                    <Style Selector="TabItem.nav-item /template/ Border#PART_Border">
                        <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}" />
                        <Setter Property="CornerRadius" Value="8" />
                        <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
                        <Setter Property="BorderThickness" Value="1" />
                    </Style>
                    <Style Selector="TabItem.nav-item:selected /template/ Border#PART_Border">
                        <Setter Property="Background" Value="{DynamicResource AppAccentSurfaceBrush}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBrush}" />
                    </Style>
                    <Style Selector="TabItem.nav-item:pointerover /template/ Border#PART_Border">
                        <Setter Property="Background" Value="{DynamicResource AppSoftSurfaceBrush}" />
                    </Style>
                    <Style Selector="TabItem.nav-item:selected Border.nav-icon">
                        <Setter Property="Background" Value="{DynamicResource AppAccentSurfaceBrush}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBrush}" />
                    </Style>
                    <Style Selector="Border.nav-icon">
                        <Setter Property="Background" Value="{DynamicResource AppSoftSurfaceBrush}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
                        <Setter Property="BorderThickness" Value="1" />
                        <Setter Property="CornerRadius" Value="4" />
                        <Setter Property="Padding" Value="4" />
                        <Setter Property="VerticalAlignment" Value="Center" />
                        <Setter Property="HorizontalAlignment" Value="Center" />
                    </Style>
                    <Style Selector="LucideIcon.nav-icon">
                        <Setter Property="Margin" Value="4"></Setter>
                    </Style>
                    <Style Selector="TabItem.nav-item TextBlock.nav-title">
                        <Setter Property="FontSize" Value="16"></Setter>
                        <Setter Property="FontWeight" Value="SemiBold" />
                        <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
                    </Style>
                    <Style Selector="TabItem.nav-item TextBlock.nav-subtitle">
                        <Setter Property="FontSize" Value="12"></Setter>
                        <Setter Property="Foreground" Value="{DynamicResource AppSecondaryTextBrush}" />
                    </Style>
                </TabControl.Styles>

                <TabItem Classes="nav-item">
                    <TabItem.Header>
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8" VerticalAlignment="Center">
                            <Border Classes="nav-icon">
                                <LucideIcon HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Kind="House" />
                            </Border>
                            <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
                                <TextBlock Classes="nav-title" Text="概览" />
                                <TextBlock Classes="nav-subtitle" Text="工作台总览" />
                            </StackPanel>
                        </Grid>
                    </TabItem.Header>
                    <pages:OverviewPage DataContext="{Binding OverviewPage}" />
                </TabItem>

                <TabItem Classes="nav-item">
                    <TabItem.Header>
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8" VerticalAlignment="Center">
                            <Border Classes="nav-icon">
                                <LucideIcon HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Kind="LibraryBig" />
                            </Border>
                            <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
                                <TextBlock Classes="nav-title" Text="素材库" />
                                <TextBlock Classes="nav-subtitle" Text="目录与队列" />
                            </StackPanel>
                        </Grid>
                    </TabItem.Header>
                    <pages:LibraryPage DataContext="{Binding LibraryPage}" />
                </TabItem>

                <TabItem Classes="nav-item">
                    <TabItem.Header>
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8" VerticalAlignment="Center">
                            <Border Classes="nav-icon">
                                <LucideIcon HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Kind="BotMessageSquare" />
                            </Border>
                            <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
                                <TextBlock Classes="nav-title" Text="描述任务" />
                                <TextBlock Classes="nav-subtitle" Text="后端工作列表" />
                            </StackPanel>
                        </Grid>
                    </TabItem.Header>
                    <pages:DescriptionTasksPage DataContext="{Binding DescriptionTasksPage}" />
                </TabItem>

                <TabItem Classes="nav-item">
                    <TabItem.Header>
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8" VerticalAlignment="Center">
                            <Border Classes="nav-icon">
                                <LucideIcon HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Kind="Settings2" />
                            </Border>
                            <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
                                <TextBlock Classes="nav-title" Text="设置" />
                                <TextBlock Classes="nav-subtitle" Text="模型与日志" />
                            </StackPanel>
                        </Grid>
                    </TabItem.Header>
                    <pages:SettingsPage DataContext="{Binding SettingsPage}" />
                </TabItem>
            </TabControl>
        </Grid>
    </Border>
</Window>
