<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AssetsLibrarySystem.Avalonia.ViewModels"
        xmlns:models="using:AssetsLibrarySystem.Application.Models"
        xmlns:pages="using:AssetsLibrarySystem.Avalonia.Views.Pages"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="AssetsLibrarySystem.Avalonia.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        d:DesignWidth="1440"
        d:DesignHeight="860"
        Icon="/Assets/avalonia-logo.ico"
        Title="Assets Library System"
        WindowDecorations="BorderOnly"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="30"
        Background="{DynamicResource AppWindowBackgroundBrush}"
        Foreground="{DynamicResource AppTextBrush}">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Border Margin="0" Padding="12">
        <Grid RowDefinitions="Auto,*,Auto" RowSpacing="12">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="4">
                <Border WindowDecorationProperties.ElementRole="TitleBar"
                        Background="Transparent"
                        Padding="8">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Border Background="{DynamicResource AppSoftSurfaceBrush}"
                                BorderBrush="{DynamicResource AppBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="6">
                            <LucideIcon Kind="LibraryBig" />
                        </Border>
                        <TextBlock FontWeight="SemiBold"
                                   FontSize="16"
                                   VerticalAlignment="Center"
                                   Text="Assets Library System" />
                    </StackPanel>
                </Border>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center" Margin="0,0,8,0">
                    <StackPanel.Styles>
                        <Style Selector="Button.window-control">
                            <Setter Property="Width" Value="24" />
                            <Setter Property="Height" Value="24" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderBrush" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="CornerRadius" Value="4" />
                            <Setter Property="Padding" Value="0" />
                        </Style>
                        <Style Selector="Button.window-control:pointerover">
                            <Setter Property="Background" Value="{DynamicResource AppSoftSurfaceBrush}" />
                        </Style>
                    </StackPanel.Styles>
                    <Button WindowDecorationProperties.ElementRole="MinimizeButton"
                            Classes="window-control"
                            Click="MinimizeWindow_Click">
                        <LucideIcon Kind="Minus" />
                    </Button>
                    <Button WindowDecorationProperties.ElementRole="MaximizeButton"
                            Classes="window-control"
                            Click="ToggleMaximizeWindow_Click">
                        <LucideIcon Kind="Square" Size="16" />
                    </Button>
                    <Button WindowDecorationProperties.ElementRole="CloseButton"
                            Classes="window-control"
                            Click="CloseWindow_Click">
                        <LucideIcon Kind="X" />
                    </Button>
                </StackPanel>
            </Grid>

            <TabControl Grid.Row="1"
                        Classes="shell-tabs"
                        Background="Transparent"
                        TabStripPlacement="Left">
                <TabControl.Styles>
                    <Style Selector="TabControl.shell-tabs > TabStrip">
                        <Setter Property="Width" Value="252" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="Padding" Value="0,10,12,0" />
                    </Style>
                    <Style Selector="TabItem.nav-item">
                        <Setter Property="Foreground" Value="{DynamicResource AppMutedTextBrush}" />
                        <Setter Property="MinHeight" Value="46" />
                        <Setter Property="Padding" Value="10,7" />
                        <Setter Property="Margin" Value="0,0,0,6" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    </Style>
                    <Style Selector="TabItem.nav-item /template/ Border#PART_Border">
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="CornerRadius" Value="8" />
                        <Setter Property="BorderBrush" Value="Transparent" />
                        <Setter Property="BorderThickness" Value="0" />
                    </Style>
                    <Style Selector="TabItem.nav-item:pointerover /template/ Border#PART_Border">
                        <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}" />
                    </Style>
                    <Style Selector="TabItem.nav-item:selected /template/ Border#PART_Border">
                        <Setter Property="Background" Value="{DynamicResource AppSoftSurfaceBrush}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
                        <Setter Property="BorderThickness" Value="1" />
                    </Style>
                    <Style Selector="Border.nav-icon">
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="BorderBrush" Value="Transparent" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="CornerRadius" Value="6" />
                        <Setter Property="Padding" Value="4" />
                    </Style>
                    <Style Selector="TextBlock.nav-title">
                        <Setter Property="FontSize" Value="15" />
                        <Setter Property="FontWeight" Value="SemiBold" />
                        <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
                    </Style>
                    <Style Selector="TextBlock.nav-subtitle">
                        <Setter Property="FontSize" Value="12" />
                        <Setter Property="Foreground" Value="{DynamicResource AppSecondaryTextBrush}" />
                    </Style>
                </TabControl.Styles>

                <TabItem Classes="nav-item">
                    <TabItem.Header>
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                            <Border Classes="nav-icon"><LucideIcon Kind="House" /></Border>
                            <StackPanel Grid.Column="1">
                                <TextBlock Classes="nav-title" Text="概览" />
                                <TextBlock Classes="nav-subtitle" Text="素材统计" />
                            </StackPanel>
                        </Grid>
                    </TabItem.Header>
                    <pages:OverviewPage DataContext="{Binding OverviewPage}" />
                </TabItem>

                <TabItem Classes="nav-item">
                    <TabItem.Header>
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                            <Border Classes="nav-icon"><LucideIcon Kind="LibraryBig" /></Border>
                            <StackPanel Grid.Column="1">
                                <TextBlock Classes="nav-title" Text="素材库" />
                                <TextBlock Classes="nav-subtitle" Text="浏览与处理" />
                            </StackPanel>
                        </Grid>
                    </TabItem.Header>
                    <pages:LibraryPage DataContext="{Binding LibraryPage}" />
                </TabItem>

                <TabItem Classes="nav-item">
                    <TabItem.Header>
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                            <Border Classes="nav-icon"><LucideIcon Kind="Settings2" /></Border>
                            <StackPanel Grid.Column="1">
                                <TextBlock Classes="nav-title" Text="设置" />
                                <TextBlock Classes="nav-subtitle" Text="模型与日志" />
                            </StackPanel>
                        </Grid>
                    </TabItem.Header>
                    <pages:SettingsPage DataContext="{Binding SettingsPage}" />
                </TabItem>
            </TabControl>

            <Border Grid.Row="2"
                    Background="{DynamicResource AppSoftSurfaceBrush}"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10,5">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                    <Button Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="0"
                            Padding="4">
                        <Button.Flyout>
                            <Flyout Placement="TopEdgeAlignedLeft">
                                <StackPanel Spacing="8" MaxWidth="440">
                                    <TextBlock FontWeight="SemiBold" Text="模型服务详情" />
                                    <TextBlock Text="{Binding BackendStatusTitle}" />
                                    <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                               Text="{Binding BackendStatusStage}" />
                                    <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                               TextWrapping="Wrap"
                                               Text="{Binding BackendEndpoint}" />
                                    <TextBlock FontWeight="SemiBold" Text="{Binding SearchModelStatusTitle}" />
                                    <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                               Text="{Binding SearchModelStatusStage}" />
                                    <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                               TextWrapping="Wrap"
                                               Text="{Binding SearchModelStatusDetail}" />
                                </StackPanel>
                            </Flyout>
                        </Button.Flyout>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <LucideIcon Kind="Cpu" Size="14" />
                            <TextBlock Text="{Binding SearchModelStatusTitle}" />
                        </StackPanel>
                    </Button>

                    <TextBlock Grid.Column="1"
                               Foreground="{DynamicResource AppSecondaryTextBrush}"
                               VerticalAlignment="Center"
                               Text="{Binding BackendStatusStage}" />

                    <Button Grid.Column="2"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="0"
                            Padding="4">
                        <Button.Flyout>
                            <Flyout Placement="TopEdgeAlignedRight">
                                <Grid RowDefinitions="Auto,*" RowSpacing="8" MinWidth="420">
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold" Text="后台任务" />
                                        <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                                   Text="描述、向量化、索引刷新与素材库扫描等异步任务" />
                                    </StackPanel>
                                    <ScrollViewer Grid.Row="1" MaxHeight="320" VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding BackgroundTasks}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="models:BackgroundTaskEntry">
                                                    <Border Background="{DynamicResource AppSoftSurfaceBrush}"
                                                            BorderBrush="{DynamicResource AppBorderBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="4"
                                                            Padding="8"
                                                            Margin="0,0,0,4">
                                                        <StackPanel Spacing="4">
                                                            <Grid ColumnDefinitions="*,Auto">
                                                                <StackPanel>
                                                                    <TextBlock FontWeight="SemiBold" Text="{Binding Title}" />
                                                                    <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                                                               Text="{Binding StageText}" />
                                                                </StackPanel>
                                                                <TextBlock Grid.Column="1" Text="{Binding StatusText}" />
                                                            </Grid>
                                                            <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                                                       TextWrapping="Wrap"
                                                                       Text="{Binding DetailText}" />
                                                            <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                                                       FontSize="12"
                                                                       Text="{Binding TimelineText}" />
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Grid>
                            </Flyout>
                        </Button.Flyout>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <LucideIcon Kind="ListTodo" Size="14" />
                            <TextBlock Text="{Binding LatestBackgroundTaskText}"
                                       TextTrimming="CharacterEllipsis"
                                       MaxWidth="360" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
