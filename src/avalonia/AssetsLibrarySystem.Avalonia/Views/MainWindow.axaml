<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AssetsLibrarySystem.Avalonia.ViewModels"
        xmlns:models="using:AssetsLibrarySystem.Avalonia.Models"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1440" d:DesignHeight="860"
        x:Class="AssetsLibrarySystem.Avalonia.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="Assets Library System">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Window.Styles>
        <Style Selector="Window">
            <Setter Property="WindowDecorations" Value="Full" />
            <Setter Property="ExtendClientAreaToDecorationsHint" Value="True" />
            <Setter Property="Background" Value="{DynamicResource AppWindowBackgroundBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
        </Style>
        <Style Selector="Border.shell">
            <Setter Property="Background" Value="{DynamicResource AppWindowBackgroundBrush}" />
        </Style>
        <Style Selector="Border.shell-header">
            <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="22" />
            <Setter Property="Padding" Value="18" />
        </Style>
        <Style Selector="Border.surface">
            <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="20" />
            <Setter Property="Padding" Value="20" />
        </Style>
        <Style Selector="Border.soft-surface">
            <Setter Property="Background" Value="{DynamicResource AppSoftSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Padding" Value="14" />
        </Style>
        <Style Selector="Border.nav-icon">
            <Setter Property="Background" Value="{DynamicResource AppSoftSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>
        <Style Selector="LucideIcon.shell-glyph">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0" />
        </Style>
        <Style Selector="TextBlock.eyebrow">
            <Setter Property="Foreground" Value="{DynamicResource AppSecondaryTextBrush}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="LetterSpacing" Value="1.4" />
        </Style>
        <Style Selector="TextBlock.hero-title">
            <Setter Property="FontSize" Value="28" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
        </Style>
        <Style Selector="TextBlock.section-title">
            <Setter Property="FontSize" Value="19" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
        </Style>
        <Style Selector="TextBlock.section-subtitle">
            <Setter Property="Foreground" Value="{DynamicResource AppSecondaryTextBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style Selector="TextBlock.nav-title">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
        </Style>
        <Style Selector="TextBlock.nav-subtitle">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{DynamicResource AppSecondaryTextBrush}" />
        </Style>
        <Style Selector="Border.metric-card">
            <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0,0,12,0" />
        </Style>
        <Style Selector="Border.selectable-card">
            <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="14" />
        </Style>
        <Style Selector="ListBox.library-list, ListBox.asset-list">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style Selector="ListBoxItem">
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style Selector="ListBoxItem:selected Border.selectable-card">
            <Setter Property="Background" Value="{DynamicResource AppAccentSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBrush}" />
        </Style>
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="{DynamicResource AppAccentBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="14,9" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style Selector="Button.secondary">
            <Setter Property="Background" Value="{DynamicResource AppSoftSurfaceBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="14,9" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="TextBox.prompt-box">
            <Setter Property="Background" Value="{DynamicResource AppSoftSurfaceBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style Selector="TabControl.shell-tabs">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="TabControl.shell-tabs > TabStrip">
            <Setter Property="Width" Value="280" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="0,8,0,0" />
        </Style>
        <Style Selector="TabControl.shell-tabs > ContentPresenter">
            <Setter Property="Padding" Value="0" />
        </Style>
        <Style Selector="TabItem.nav-item">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{DynamicResource AppMutedTextBrush}" />
            <Setter Property="MinHeight" Value="56" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="TabItem.nav-item /template/ Border#PART_Border">
            <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="TabItem.nav-item:selected /template/ Border#PART_Border">
            <Setter Property="Background" Value="{DynamicResource AppAccentSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBrush}" />
        </Style>
        <Style Selector="TabItem.nav-item:pointerover /template/ Border#PART_Border">
            <Setter Property="Background" Value="{DynamicResource AppSoftSurfaceBrush}" />
        </Style>
        <Style Selector="TabItem.nav-item:selected Border.nav-icon">
            <Setter Property="Background" Value="{DynamicResource AppAccentSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBrush}" />
        </Style>
    </Window.Styles>

    <Border Classes="shell" Padding="20">
        <Grid RowDefinitions="Auto,*" RowSpacing="16">
            <Border Classes="shell-header">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16">
                    <Border
                        Background="{DynamicResource AppAccentSurfaceBrush}"
                        BorderBrush="{DynamicResource AppAccentBrush}"
                        BorderThickness="1"
                        CornerRadius="18"
                        Width="48"
                        Height="48"
                        Padding="0">
                        <LucideIcon
                            Classes="shell-glyph"
                            Kind="LibraryBig" />
                    </Border>

                    <StackPanel Grid.Column="1" Spacing="2">
                        <TextBlock FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource AppTextBrush}" Text="Assets Library System" />
                        <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}" Text="Windows 11 Fluent shell · 左侧导航，右侧页面" />
                    </StackPanel>

                    <Border
                        Grid.Column="2"
                        Background="{DynamicResource AppSoftSurfaceBrush}"
                        BorderBrush="{DynamicResource AppBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="12,10">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Border
                                Background="{DynamicResource AppAccentSurfaceBrush}"
                                BorderBrush="{DynamicResource AppAccentBrush}"
                                BorderThickness="1"
                                CornerRadius="999"
                                Padding="7">
                                <LucideIcon
                                    Classes="shell-glyph"
                                    Kind="Bot" />
                            </Border>
                            <StackPanel Spacing="2">
                                <TextBlock FontSize="12" FontWeight="SemiBold" Text="{Binding BackendStatusTitle}" />
                                <TextBlock FontSize="11" Foreground="{DynamicResource AppSecondaryTextBrush}" Text="{Binding BackendEndpoint}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <TabControl Grid.Row="1" Classes="shell-tabs" TabStripPlacement="Left">
                <TabItem Classes="nav-item">
                    <TabItem.Header>
                        <Grid ColumnDefinitions="36,*" ColumnSpacing="10" VerticalAlignment="Center">
                            <Border Classes="nav-icon">
                                <LucideIcon Classes="shell-glyph" Kind="House" />
                            </Border>
                            <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                <TextBlock Classes="nav-title" Text="概览" />
                                <TextBlock Classes="nav-subtitle" Text="工作台总览" />
                            </StackPanel>
                        </Grid>
                    </TabItem.Header>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Grid ColumnDefinitions="*,320" ColumnSpacing="20">
                            <StackPanel Spacing="20">
                                <Border Classes="surface">
                                    <StackPanel Spacing="10">
                                        <TextBlock Classes="eyebrow" Text="Assets Library System / Desktop Shell" />
                                        <StackPanel Orientation="Horizontal" Spacing="10">
                                            <Border
                                                Background="{DynamicResource AppAccentSurfaceBrush}"
                                                BorderBrush="{DynamicResource AppAccentBrush}"
                                                BorderThickness="1"
                                                CornerRadius="14"
                                                Padding="9">
                                                <LucideIcon Classes="shell-glyph" Kind="House" Size="20" />
                                            </Border>
                                            <TextBlock Classes="hero-title" Text="桌面端负责素材管理，Python 只做模型网关" />
                                        </StackPanel>
                                        <TextBlock
                                            Classes="section-subtitle"
                                            Text="主窗口现在收敛为 Windows 11 Fluent 风格的桌面工作台，左侧导航切换页面，右侧承载素材库、素材详情和模型能力面。" />
                                    </StackPanel>
                                </Border>

                                <ItemsControl ItemsSource="{Binding Metrics}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="4" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="models:DashboardMetric">
                                            <Border Classes="metric-card">
                                                <StackPanel Spacing="8">
                                                    <TextBlock Classes="eyebrow" Text="{Binding Label}" />
                                                    <TextBlock FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource AppTextBrush}" Text="{Binding Value}" />
                                                    <TextBlock Classes="section-subtitle" Text="{Binding Hint}" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Border Classes="surface">
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="18">
                                        <StackPanel Spacing="10">
                                            <TextBlock Classes="eyebrow" Text="Workspace" />
                                            <TextBlock Classes="section-title" Text="{Binding WorkspaceTitle}" />
                                            <TextBlock Classes="section-subtitle" Text="{Binding WorkspaceSummary}" />
                                            <Border Classes="soft-surface">
                                                <TextBlock Foreground="{DynamicResource AppMutedTextBrush}" TextWrapping="Wrap" Text="{Binding AssetSummary}" />
                                            </Border>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Spacing="10">
                                            <TextBlock Classes="eyebrow" Text="Operator Notice" />
                                            <TextBlock Classes="section-title" Text="当前处理原则" />
                                            <TextBlock Classes="section-subtitle" Text="{Binding OperatorNotice}" />
                                            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                                <Button Classes="secondary" Command="{Binding RefreshWorkspaceCommand}" Content="刷新桌面工作台" />
                                                <Button Grid.Column="1" Classes="secondary" Command="{Binding MarkManagedCommand}" Content="标记为 .NET 已接管" />
                                            </Grid>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="20">
                                <Border Classes="surface">
                                    <StackPanel Spacing="8">
                                        <TextBlock Classes="eyebrow" Text="Backend Status" />
                                        <StackPanel Orientation="Horizontal" Spacing="10">
                                            <LucideIcon Classes="shell-glyph" Kind="Bot" Size="20" />
                                            <TextBlock FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource AppTextBrush}" Text="{Binding BackendStatusTitle}" />
                                        </StackPanel>
                                        <TextBlock Classes="section-subtitle" Text="{Binding BackendStatusDetail}" />
                                        <Border Classes="soft-surface">
                                            <TextBlock Foreground="{DynamicResource AppTextBrush}" Text="{Binding BackendEndpoint}" />
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <Border Classes="surface">
                                    <StackPanel Spacing="10">
                                        <TextBlock Classes="eyebrow" Text="Selected Asset" />
                                        <StackPanel Orientation="Horizontal" Spacing="10">
                                            <LucideIcon Classes="shell-glyph" Kind="FileText" Size="20" />
                                            <TextBlock FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource AppTextBrush}" Text="{Binding SelectedAssetName}" />
                                        </StackPanel>
                                        <TextBlock Foreground="{DynamicResource AppAccentBrush}" Text="{Binding SelectedAssetLibrary}" />
                                        <TextBlock Classes="section-subtitle" Text="{Binding SelectedAssetPath}" />
                                        <TextBlock Foreground="{DynamicResource AppMutedTextBrush}" TextWrapping="Wrap" Text="{Binding SelectedAssetDetail}" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </TabItem>

                <TabItem Classes="nav-item">
                    <TabItem.Header>
                        <Grid ColumnDefinitions="36,*" ColumnSpacing="10" VerticalAlignment="Center">
                            <Border Classes="nav-icon">
                                <LucideIcon Classes="shell-glyph" Kind="LibraryBig" />
                            </Border>
                            <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                <TextBlock Classes="nav-title" Text="素材库" />
                                <TextBlock Classes="nav-subtitle" Text="目录与队列" />
                            </StackPanel>
                        </Grid>
                    </TabItem.Header>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Grid ColumnDefinitions="340,*" ColumnSpacing="20">
                            <Border Classes="surface">
                                <StackPanel Spacing="16">
                                    <StackPanel Spacing="4">
                                        <TextBlock Classes="eyebrow" Text="Local Libraries" />
                                        <TextBlock Classes="section-title" Text="素材库导航" />
                                        <TextBlock Classes="section-subtitle" Text="左侧聚焦素材库目录，右侧展示当前库的素材条目。" />
                                    </StackPanel>

                                    <ListBox
                                        Classes="library-list"
                                        ItemsSource="{Binding Libraries}"
                                        SelectedItem="{Binding SelectedLibrary}">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate x:DataType="models:LibraryWorkspace">
                                                <Border Classes="selectable-card">
                                                    <StackPanel Spacing="8">
                                                        <DockPanel>
                                                            <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource AppTextBrush}" Text="{Binding Name}" />
                                                            <Border
                                                                DockPanel.Dock="Right"
                                                                Background="{DynamicResource AppAccentSurfaceBrush}"
                                                                CornerRadius="999"
                                                                Padding="10,4">
                                                                <TextBlock Foreground="{DynamicResource AppAccentBrush}" Text="{Binding AssetCount}" />
                                                            </Border>
                                                        </DockPanel>
                                                        <TextBlock Classes="section-subtitle" Text="{Binding RootPath}" />
                                                        <TextBlock Foreground="{DynamicResource AppMutedTextBrush}" TextWrapping="Wrap" Text="{Binding Summary}" />
                                                        <TextBlock Foreground="{DynamicResource AppAccentBrush}" Text="{Binding SyncMode}" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Classes="surface">
                                <Grid RowDefinitions="Auto,Auto,*" RowSpacing="16">
                                    <StackPanel Spacing="4">
                                        <TextBlock Classes="eyebrow" Text="Asset Queue" />
                                        <TextBlock Classes="section-title" Text="{Binding WorkspaceTitle}" />
                                        <TextBlock Classes="section-subtitle" Text="{Binding WorkspaceSummary}" />
                                    </StackPanel>

                                    <Border Grid.Row="1" Classes="soft-surface">
                                        <TextBlock Foreground="{DynamicResource AppMutedTextBrush}" TextWrapping="Wrap" Text="{Binding AssetSummary}" />
                                    </Border>

                                    <ListBox
                                        Grid.Row="2"
                                        Classes="asset-list"
                                        ItemsSource="{Binding VisibleAssets}"
                                        SelectedItem="{Binding SelectedAsset}">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate x:DataType="models:ManagedAssetRecord">
                                                <Border Classes="selectable-card">
                                                    <Grid ColumnDefinitions="*,120" RowDefinitions="Auto,Auto,Auto" RowSpacing="8">
                                                        <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource AppTextBrush}" Text="{Binding Name}" />
                                                        <Border
                                                            Grid.Column="1"
                                                            HorizontalAlignment="Right"
                                                            Background="{DynamicResource AppBadgeBrush}"
                                                            CornerRadius="999"
                                                            Padding="10,4">
                                                            <TextBlock Foreground="{DynamicResource AppAccentBrush}" Text="{Binding AssetType}" />
                                                        </Border>
                                                        <TextBlock Grid.Row="1" Classes="section-subtitle" Text="{Binding RelativePath}" />
                                                        <TextBlock
                                                            Grid.Row="1"
                                                            Grid.Column="1"
                                                            HorizontalAlignment="Right"
                                                            Foreground="{DynamicResource AppSecondaryTextBrush}"
                                                            Text="{Binding Stage}" />
                                                        <TextBlock
                                                            Grid.Row="2"
                                                            Grid.ColumnSpan="2"
                                                            Foreground="{DynamicResource AppMutedTextBrush}"
                                                            TextWrapping="Wrap"
                                                            Text="{Binding Summary}" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Grid>
                            </Border>
                        </Grid>
                    </ScrollViewer>
                </TabItem>

                <TabItem Classes="nav-item">
                    <TabItem.Header>
                        <Grid ColumnDefinitions="36,*" ColumnSpacing="10" VerticalAlignment="Center">
                            <Border Classes="nav-icon">
                                <LucideIcon Classes="shell-glyph" Kind="FileText" />
                            </Border>
                            <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                <TextBlock Classes="nav-title" Text="素材详情" />
                                <TextBlock Classes="nav-subtitle" Text="状态与操作" />
                            </StackPanel>
                        </Grid>
                    </TabItem.Header>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Grid ColumnDefinitions="*,300" ColumnSpacing="20">
                            <Border Classes="surface">
                                <StackPanel Spacing="14">
                                    <TextBlock Classes="eyebrow" Text="Selected Asset" />
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <LucideIcon Classes="shell-glyph" Kind="FileText" Size="20" />
                                        <TextBlock Classes="section-title" Text="{Binding SelectedAssetName}" />
                                    </StackPanel>
                                    <TextBlock Foreground="{DynamicResource AppAccentBrush}" Text="{Binding SelectedAssetLibrary}" />
                                    <TextBlock Classes="section-subtitle" Text="{Binding SelectedAssetPath}" />

                                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12">
                                        <Border Classes="soft-surface">
                                            <StackPanel Spacing="4">
                                                <TextBlock Classes="eyebrow" Text="Type" />
                                                <TextBlock Foreground="{DynamicResource AppTextBrush}" Text="{Binding SelectedAssetType}" />
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Column="1" Classes="soft-surface">
                                            <StackPanel Spacing="4">
                                                <TextBlock Classes="eyebrow" Text="Stage" />
                                                <TextBlock Foreground="{DynamicResource AppTextBrush}" Text="{Binding SelectedAssetStage}" />
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Column="2" Classes="soft-surface">
                                            <StackPanel Spacing="4">
                                                <TextBlock Classes="eyebrow" Text="AI State" />
                                                <TextBlock Foreground="{DynamicResource AppTextBrush}" Text="{Binding SelectedAssetAiState}" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <Border Classes="soft-surface">
                                        <TextBlock Foreground="{DynamicResource AppMutedTextBrush}" TextWrapping="Wrap" Text="{Binding SelectedAssetDetail}" />
                                    </Border>

                                    <ItemsControl ItemsSource="{Binding SelectedAssetTags}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border
                                                    Margin="0,0,8,8"
                                                    Background="{DynamicResource AppAccentSurfaceBrush}"
                                                    CornerRadius="999"
                                                    Padding="10,5">
                                                    <TextBlock Foreground="{DynamicResource AppAccentBrush}" Text="{Binding .}" />
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Classes="surface">
                                <StackPanel Spacing="12">
                                    <TextBlock Classes="eyebrow" Text="Actions" />
                                    <TextBlock Classes="section-title" Text="素材操作" />
                                    <TextBlock Classes="section-subtitle" Text="保留当前占位交互，后续再接真实目录扫描、描述任务和索引流水线。" />
                                    <Button Classes="primary" Command="{Binding QueueDescriptionCommand}" Content="排入描述任务" />
                                    <Button Classes="secondary" Command="{Binding QueueEmbeddingCommand}" Content="排入索引任务" />
                                    <Button Classes="secondary" Command="{Binding MarkManagedCommand}" Content="标记为 .NET 已接管" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </ScrollViewer>
                </TabItem>

                <TabItem Classes="nav-item">
                    <TabItem.Header>
                        <Grid ColumnDefinitions="36,*" ColumnSpacing="10" VerticalAlignment="Center">
                            <Border Classes="nav-icon">
                                <LucideIcon Classes="shell-glyph" Kind="Bot" />
                            </Border>
                            <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                <TextBlock Classes="nav-title" Text="模型能力" />
                                <TextBlock Classes="nav-subtitle" Text="HTTP 网关" />
                            </StackPanel>
                        </Grid>
                    </TabItem.Header>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Grid ColumnDefinitions="340,*" ColumnSpacing="20">
                            <Border Classes="surface">
                                <StackPanel Spacing="10">
                                    <TextBlock Classes="eyebrow" Text="Model Gateway" />
                                    <TextBlock Classes="section-title" Text="Python HTTP 能力面" />
                                    <TextBlock Classes="section-subtitle" Text="{Binding BackendStatusDetail}" />
                                    <Border Classes="soft-surface">
                                        <StackPanel Spacing="6">
                                            <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource AppTextBrush}" Text="{Binding BackendStatusTitle}" />
                                            <TextBlock Foreground="{DynamicResource AppAccentBrush}" Text="{Binding BackendEndpoint}" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Classes="surface">
                                <StackPanel Spacing="14">
                                    <ItemsControl ItemsSource="{Binding AiCapabilities}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="models:AiCapabilityRecord">
                                                <Border
                                                    Margin="0,0,0,10"
                                                    Background="{DynamicResource AppSurfaceBrush}"
                                                    BorderBrush="{DynamicResource AppBorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="14"
                                                    Padding="14">
                                                    <StackPanel Spacing="6">
                                                        <DockPanel>
                                                            <TextBlock FontWeight="SemiBold" Foreground="{DynamicResource AppTextBrush}" Text="{Binding Name}" />
                                                            <TextBlock DockPanel.Dock="Right" Foreground="{DynamicResource AppAccentBrush}" Text="{Binding Endpoint}" />
                                                        </DockPanel>
                                                        <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}" TextWrapping="Wrap" Text="{Binding Summary}" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <TextBlock Classes="eyebrow" Text="Prompt Draft" />
                                    <TextBox
                                        Classes="prompt-box"
                                        MinHeight="140"
                                        AcceptsReturn="True"
                                        Text="{Binding PromptDraft}" />
                                    <Button Classes="primary" Command="{Binding SubmitPromptCommand}" Content="准备发送提示词" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </ScrollViewer>
                </TabItem>

                <TabItem Classes="nav-item">
                    <TabItem.Header>
                        <Grid ColumnDefinitions="36,*" ColumnSpacing="10" VerticalAlignment="Center">
                            <Border Classes="nav-icon">
                                <LucideIcon Classes="shell-glyph" Kind="History" />
                            </Border>
                            <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                <TextBlock Classes="nav-title" Text="活动纪要" />
                                <TextBlock Classes="nav-subtitle" Text="运行日志" />
                            </StackPanel>
                        </Grid>
                    </TabItem.Header>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Border Classes="surface">
                            <StackPanel Spacing="14">
                                <TextBlock Classes="eyebrow" Text="Activity Feed" />
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <LucideIcon Classes="shell-glyph" Kind="History" Size="20" />
                                    <TextBlock Classes="section-title" Text="桌面端任务纪要" />
                                </StackPanel>
                                <TextBlock Classes="section-subtitle" Text="保留近期桌面端操作与模型网关状态，便于后续扩展为真实任务流水线日志。" />
                                <ItemsControl ItemsSource="{Binding ActivityFeed}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border
                                                Margin="0,0,0,10"
                                                Background="{DynamicResource AppSurfaceBrush}"
                                                BorderBrush="{DynamicResource AppBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="12"
                                                Padding="12">
                                                <TextBlock Foreground="{DynamicResource AppMutedTextBrush}" TextWrapping="Wrap" Text="{Binding .}" />
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>
    </Border>
</Window>
