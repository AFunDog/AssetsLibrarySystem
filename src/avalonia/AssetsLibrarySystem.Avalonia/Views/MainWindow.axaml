<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AssetsLibrarySystem.Avalonia.ViewModels"
        xmlns:pages="using:AssetsLibrarySystem.Avalonia.Views.Pages"
        mc:Ignorable="d"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        x:Class="AssetsLibrarySystem.Avalonia.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        d:DesignWidth="1440"
        d:DesignHeight="860"
        Icon="/Assets/avalonia-logo.ico"
        Title="Assets Library System">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Window.Styles>
        <Style Selector="Window">
            <Setter Property="WindowDecorations" Value="BorderOnly" />
            <Setter Property="ExtendClientAreaToDecorationsHint" Value="True" />
            <Setter Property="ExtendClientAreaTitleBarHeightHint" Value="34" />
            <Setter Property="Background" Value="{DynamicResource AppWindowBackgroundBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
        </Style>
        <Style Selector="Border.shell-header">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="Padding" Value="0" />
        </Style>
        <Style Selector="Border.nav-icon">
            <Setter Property="Background" Value="{DynamicResource AppSoftSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>
        <Style Selector="LucideIcon.shell-glyph">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0" />
        </Style>
        <Style Selector="TextBlock.nav-title">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
        </Style>
        <Style Selector="TextBlock.nav-subtitle">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{DynamicResource AppSecondaryTextBrush}" />
        </Style>
        <Style Selector="Button.window-control">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="0" />
        </Style>
        <Style Selector="Button.window-control:pointerover">
            <Setter Property="Background" Value="{DynamicResource AppSoftSurfaceBrush}" />
        </Style>
        <Style Selector="Button.window-control:pressed">
            <Setter Property="Background" Value="{DynamicResource AppAccentSurfaceBrush}" />
        </Style>
        <Style Selector="TabControl.shell-tabs">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="TabControl.shell-tabs > TabStrip">
            <Setter Property="Width" Value="280" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="0,8,0,0" />
        </Style>
        <Style Selector="TabControl.shell-tabs > ContentPresenter">
            <Setter Property="Padding" Value="0" />
        </Style>
        <Style Selector="TabItem.nav-item">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{DynamicResource AppMutedTextBrush}" />
            <Setter Property="MinHeight" Value="56" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="TabItem.nav-item /template/ Border#PART_Border">
            <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="TabItem.nav-item:selected /template/ Border#PART_Border">
            <Setter Property="Background" Value="{DynamicResource AppAccentSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBrush}" />
        </Style>
        <Style Selector="TabItem.nav-item:pointerover /template/ Border#PART_Border">
            <Setter Property="Background" Value="{DynamicResource AppSoftSurfaceBrush}" />
        </Style>
        <Style Selector="TabItem.nav-item:selected Border.nav-icon">
            <Setter Property="Background" Value="{DynamicResource AppAccentSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBrush}" />
        </Style>
    </Window.Styles>

    <Border Margin="8">
        <Grid RowDefinitions="Auto,*" RowSpacing="16">
            <Border Classes="shell-header">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <Border WindowDecorationProperties.ElementRole="TitleBar"
                            Background="Transparent"
                            CornerRadius="0"
                            Padding="0">
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <Border Background="{DynamicResource AppAccentSurfaceBrush}"
                                    BorderBrush="{DynamicResource AppAccentBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Width="20"
                                    Height="20"
                                    Padding="0">
                                <LucideIcon Classes="shell-glyph" Kind="LibraryBig" Size="12" />
                            </Border>
                            <StackPanel Spacing="0" VerticalAlignment="Center">
                                <TextBlock FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource AppTextBrush}"
                                           Text="Assets Library System" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                        <Border Background="Transparent" BorderThickness="0" CornerRadius="0" Padding="0">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Border Background="{DynamicResource AppAccentSurfaceBrush}"
                                        BorderBrush="{DynamicResource AppAccentBrush}"
                                        BorderThickness="1"
                                        CornerRadius="999"
                                        Width="20"
                                        Height="20">
                                    <LucideIcon Classes="shell-glyph" Kind="Bot" Size="12" />
                                </Border>
                                <StackPanel Spacing="2">
                                    <TextBlock FontSize="11"
                                               FontWeight="SemiBold"
                                               Text="{Binding BackendStatusTitle}" />
                                    <TextBlock FontSize="10"
                                               Foreground="{DynamicResource AppSecondaryTextBrush}"
                                               Text="{Binding BackendEndpoint}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Button WindowDecorationProperties.ElementRole="MinimizeButton"
                                Classes="window-control"
                                Click="MinimizeWindow_Click">
                            <LucideIcon Classes="shell-glyph" Kind="Minus" Size="12" />
                        </Button>
                        <Button WindowDecorationProperties.ElementRole="MaximizeButton"
                                Classes="window-control"
                                Click="ToggleMaximizeWindow_Click">
                            <LucideIcon Classes="shell-glyph" Kind="Square" Size="12" />
                        </Button>
                        <Button WindowDecorationProperties.ElementRole="CloseButton"
                                Classes="window-control"
                                Click="CloseWindow_Click">
                            <LucideIcon Classes="shell-glyph" Kind="X" Size="12" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <TabControl Grid.Row="1" Classes="shell-tabs" TabStripPlacement="Left">
                <TabItem Classes="nav-item">
                    <TabItem.Header>
                        <Grid ColumnDefinitions="36,*" ColumnSpacing="10" VerticalAlignment="Center">
                            <Border Classes="nav-icon">
                                <LucideIcon Classes="shell-glyph" Kind="House" />
                            </Border>
                            <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                <TextBlock Classes="nav-title" Text="概览" />
                                <TextBlock Classes="nav-subtitle" Text="工作台总览" />
                            </StackPanel>
                        </Grid>
                    </TabItem.Header>
                    <pages:OverviewPage />
                </TabItem>

                <TabItem Classes="nav-item">
                    <TabItem.Header>
                        <Grid ColumnDefinitions="36,*" ColumnSpacing="10" VerticalAlignment="Center">
                            <Border Classes="nav-icon">
                                <LucideIcon Classes="shell-glyph" Kind="LibraryBig" />
                            </Border>
                            <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                <TextBlock Classes="nav-title" Text="素材库" />
                                <TextBlock Classes="nav-subtitle" Text="目录与队列" />
                            </StackPanel>
                        </Grid>
                    </TabItem.Header>
                    <pages:LibraryPage />
                </TabItem>

                <TabItem Classes="nav-item">
                    <TabItem.Header>
                        <Grid ColumnDefinitions="36,*" ColumnSpacing="10" VerticalAlignment="Center">
                            <Border Classes="nav-icon">
                                <LucideIcon Classes="shell-glyph" Kind="FileText" />
                            </Border>
                            <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                <TextBlock Classes="nav-title" Text="素材详情" />
                                <TextBlock Classes="nav-subtitle" Text="状态与操作" />
                            </StackPanel>
                        </Grid>
                    </TabItem.Header>
                    <pages:AssetDetailPage />
                </TabItem>

                <TabItem Classes="nav-item">
                    <TabItem.Header>
                        <Grid ColumnDefinitions="36,*" ColumnSpacing="10" VerticalAlignment="Center">
                            <Border Classes="nav-icon">
                                <LucideIcon Classes="shell-glyph" Kind="Bot" />
                            </Border>
                            <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                <TextBlock Classes="nav-title" Text="模型能力" />
                                <TextBlock Classes="nav-subtitle" Text="HTTP 网关" />
                            </StackPanel>
                        </Grid>
                    </TabItem.Header>
                    <pages:ModelGatewayPage />
                </TabItem>

                <TabItem Classes="nav-item">
                    <TabItem.Header>
                        <Grid ColumnDefinitions="36,*" ColumnSpacing="10" VerticalAlignment="Center">
                            <Border Classes="nav-icon">
                                <LucideIcon Classes="shell-glyph" Kind="History" />
                            </Border>
                            <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                <TextBlock Classes="nav-title" Text="活动纪要" />
                                <TextBlock Classes="nav-subtitle" Text="运行日志" />
                            </StackPanel>
                        </Grid>
                    </TabItem.Header>
                    <pages:ActivityPage />
                </TabItem>
            </TabControl>
        </Grid>
    </Border>
</Window>
