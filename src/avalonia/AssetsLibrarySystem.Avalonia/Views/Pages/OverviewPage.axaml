<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:pagevm="using:AssetsLibrarySystem.Avalonia.ViewModels"
             xmlns:models="using:AssetsLibrarySystem.Application.Models"
             x:Class="AssetsLibrarySystem.Avalonia.Views.Pages.OverviewPage"
             x:DataType="pagevm:OverviewPageViewModel">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="8">
            <Border Background="{DynamicResource AppSurfaceBrush}"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <StackPanel Spacing="4">
                        <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                   FontWeight="SemiBold"
                                   LetterSpacing="1.2"
                                   Text="概览" />
                        <TextBlock FontWeight="SemiBold" Text="素材库统计" />
                        <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                   TextWrapping="Wrap"
                                   Text="统计当前已加载素材库中的文件类型、描述和向量化进度。" />
                    </StackPanel>
                    <Button Grid.Column="1"
                            Background="{DynamicResource AppSoftSurfaceBrush}"
                            BorderBrush="{DynamicResource AppBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="10,8"
                            VerticalAlignment="Center"
                            Command="{Binding RefreshWorkspaceCommand}"
                            Content="刷新当前素材库" />
                </Grid>
            </Border>

            <ItemsControl ItemsSource="{Binding Metrics}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="4" ColumnSpacing="4" RowSpacing="4"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:DashboardMetric">
                        <Border Background="{DynamicResource AppSurfaceBrush}"
                                BorderBrush="{DynamicResource AppBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="12">
                            <StackPanel Spacing="4">
                                <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                           FontWeight="SemiBold"
                                           Text="{Binding Label}" />
                                <TextBlock FontSize="20"
                                           FontWeight="SemiBold"
                                           Text="{Binding Value}" />
                                <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                           TextWrapping="Wrap"
                                           Text="{Binding Hint}" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Border Background="{DynamicResource AppSurfaceBrush}"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12">
                <StackPanel Spacing="8">
                    <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                               FontWeight="SemiBold"
                               Text="当前素材库" />
                    <TextBlock FontWeight="SemiBold" Text="{Binding WorkspaceTitle}" />
                    <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                               TextWrapping="Wrap"
                               Text="{Binding WorkspaceSummary}" />
                    <Border Background="{DynamicResource AppSoftSurfaceBrush}"
                            BorderBrush="{DynamicResource AppBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="8">
                        <TextBlock TextWrapping="Wrap" Text="{Binding AssetSummary}" />
                    </Border>
                    <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                               TextWrapping="Wrap"
                               Text="{Binding OperatorNotice}" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
