<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AssetsLibrarySystem.Avalonia.ViewModels"
             xmlns:pagevm="using:AssetsLibrarySystem.Avalonia.ViewModels"
             xmlns:models="using:AssetsLibrarySystem.Application.Models"
             xmlns:lucide="clr-namespace:Lucide.Avalonia;assembly=Lucide.Avalonia"
             x:Class="AssetsLibrarySystem.Avalonia.Views.Pages.OverviewPage"
             x:DataType="pagevm:OverviewPageViewModel">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid ColumnDefinitions="*,280" ColumnSpacing="8">
            <StackPanel Spacing="8">
                <Border Background="{DynamicResource AppSurfaceBrush}"
                        BorderBrush="{DynamicResource AppBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <StackPanel Spacing="4">
                            <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                       FontWeight="SemiBold"
                                       LetterSpacing="1.2"
                                       Text="总览" />
                            <TextBlock Foreground="{DynamicResource AppTextBrush}"
                                       FontWeight="SemiBold"
                                       Text="素材工作台" />
                            <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                       TextWrapping="Wrap"
                                       Text="桌面端负责目录、扫描、检索和描述编排，Python 只负责模型网关。" />
                        </StackPanel>

                        <!-- <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center"> -->
                        <!--     <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}" -->
                        <!--                FontWeight="SemiBold" -->
                        <!--                LetterSpacing="1.2" -->
                        <!--                Text="后端状态" /> -->
                        <!--     <TextBlock Foreground="{DynamicResource AppTextBrush}" -->
                        <!--                FontWeight="SemiBold" -->
                        <!--                Text="{Binding BackendStatusTitle}" /> -->
                        <!--     <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}" -->
                        <!--                Text="{Binding BackendStatusStage}" /> -->
                        <!-- </StackPanel> -->
                    </Grid>
                </Border>

                <ItemsControl ItemsSource="{Binding Metrics}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="4" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:DashboardMetric">
                            <Border Background="{DynamicResource AppSurfaceBrush}"
                                    BorderBrush="{DynamicResource AppBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="12"
                                    Margin="0,0,4,4">
                                <StackPanel Spacing="4">
                                    <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                               FontWeight="SemiBold"
                                               LetterSpacing="1.2"
                                               Text="{Binding Label}" />
                                    <TextBlock Foreground="{DynamicResource AppTextBrush}"
                                               FontWeight="SemiBold"
                                               Text="{Binding Value}" />
                                    <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                               TextWrapping="Wrap"
                                               Text="{Binding Hint}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Border Background="{DynamicResource AppSurfaceBrush}"
                        BorderBrush="{DynamicResource AppBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12">
                    <StackPanel Spacing="8">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                            <StackPanel Spacing="4">
                                <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                           FontWeight="SemiBold"
                                           LetterSpacing="1.2"
                                           Text="工作区" />
                                <TextBlock Foreground="{DynamicResource AppTextBrush}"
                                           FontWeight="SemiBold"
                                           Text="{Binding WorkspaceTitle}" />
                                <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                           TextWrapping="Wrap"
                                           Text="{Binding WorkspaceSummary}" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                <Button Background="{DynamicResource AppSoftSurfaceBrush}"
                                        Foreground="{DynamicResource AppTextBrush}"
                                        BorderBrush="{DynamicResource AppBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="10,8"
                                        MinHeight="32"
                                        Command="{Binding RefreshWorkspaceCommand}"
                                        Content="刷新" />
                                <Button Background="{DynamicResource AppSoftSurfaceBrush}"
                                        Foreground="{DynamicResource AppTextBrush}"
                                        BorderBrush="{DynamicResource AppBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="10,8"
                                        MinHeight="32"
                                        Command="{Binding MarkManagedCommand}"
                                        Content="标记接管" />
                            </StackPanel>
                        </Grid>

                        <Border Background="{DynamicResource AppSoftSurfaceBrush}"
                                BorderBrush="{DynamicResource AppBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="8">
                            <TextBlock Foreground="{DynamicResource AppTextBrush}"
                                       TextWrapping="Wrap"
                                       Text="{Binding AssetSummary}" />
                        </Border>

                        <Border Background="{DynamicResource AppSoftSurfaceBrush}"
                                BorderBrush="{DynamicResource AppBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="8">
                            <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                       TextWrapping="Wrap"
                                       Text="{Binding OperatorNotice}" />
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Grid.Column="1" Spacing="8">
                <!-- <Border Background="{DynamicResource AppSurfaceBrush}" -->
                <!--         BorderBrush="{DynamicResource AppBorderBrush}" -->
                <!--         BorderThickness="1" -->
                <!--         CornerRadius="8" -->
                <!--         Padding="12"> -->
                <!--     <StackPanel Spacing="4"> -->
                <!--         <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}" -->
                <!--                    FontWeight="SemiBold" -->
                <!--                    LetterSpacing="1.2" -->
                <!--                    Text="后端详情" /> -->
                <!--         <TextBlock Foreground="{DynamicResource AppTextBrush}" -->
                <!--                    FontWeight="SemiBold" -->
                <!--                    Text="{Binding BackendStatusDetail}" /> -->
                <!--         <Border Background="{DynamicResource AppSoftSurfaceBrush}" -->
                <!--                 BorderBrush="{DynamicResource AppBorderBrush}" -->
                <!--                 BorderThickness="1" -->
                <!--                 CornerRadius="4" -->
                <!--                 Padding="8"> -->
                <!--             <TextBlock Foreground="{DynamicResource AppAccentBrush}" -->
                <!--                        Text="{Binding BackendEndpoint}" /> -->
                <!--         </Border> -->
                <!--     </StackPanel> -->
                <!-- </Border> -->

                <Border Background="{DynamicResource AppSurfaceBrush}"
                        BorderBrush="{DynamicResource AppBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12">
                    <StackPanel Spacing="8">
                        <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                   FontWeight="SemiBold"
                                   LetterSpacing="1.2"
                                   Text="已选素材" />
                        <TextBlock Foreground="{DynamicResource AppTextBrush}"
                                   FontWeight="SemiBold"
                                   Text="{Binding SelectedAssetName}" />
                        <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                   Text="{Binding SelectedAssetLibrary}" />
                        <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                   TextWrapping="Wrap"
                                   Text="{Binding SelectedAssetPath}" />

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="4" RowDefinitions="Auto,Auto" RowSpacing="4">
                            <Border Background="{DynamicResource AppSoftSurfaceBrush}"
                                    BorderBrush="{DynamicResource AppBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="8">
                                <StackPanel Spacing="2">
                                    <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                               FontWeight="SemiBold"
                                               LetterSpacing="1.2"
                                               Text="类型" />
                                    <TextBlock Foreground="{DynamicResource AppTextBrush}" Text="{Binding SelectedAssetType}" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1"
                                    Background="{DynamicResource AppSoftSurfaceBrush}"
                                    BorderBrush="{DynamicResource AppBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="8">
                                <StackPanel Spacing="2">
                                    <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                               FontWeight="SemiBold"
                                               LetterSpacing="1.2"
                                               Text="阶段" />
                                    <TextBlock Foreground="{DynamicResource AppTextBrush}" Text="{Binding SelectedAssetStage}" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="1"
                                    Grid.ColumnSpan="2"
                                    Background="{DynamicResource AppSoftSurfaceBrush}"
                                    BorderBrush="{DynamicResource AppBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="8">
                                <StackPanel Spacing="2">
                                    <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                               FontWeight="SemiBold"
                                               LetterSpacing="1.2"
                                               Text="状态" />
                                    <TextBlock Foreground="{DynamicResource AppTextBrush}" Text="{Binding SelectedAssetAiState}" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Background="{DynamicResource AppSoftSurfaceBrush}"
                                BorderBrush="{DynamicResource AppBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="8">
                            <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                       TextWrapping="Wrap"
                                       Text="{Binding SelectedAssetDetail}" />
                        </Border>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource AppSurfaceBrush}"
                        BorderBrush="{DynamicResource AppBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12">
                    <StackPanel Spacing="8">
                        <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                   FontWeight="SemiBold"
                                   LetterSpacing="1.2"
                                   Text="动态" />
                        <TextBlock Foreground="{DynamicResource AppTextBrush}"
                                   FontWeight="SemiBold"
                                   Text="活动纪要" />
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Height="220"
                                      >
                            <ItemsControl ItemsSource="{Binding ActivityFeed}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <VirtualizingStackPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource AppSoftSurfaceBrush}"
                                                BorderBrush="{DynamicResource AppBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="4"
                                                Padding="8"
                                                Margin="0,0,0,4">
                                            <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                                       TextWrapping="Wrap"
                                                       Text="{Binding .}" />
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
