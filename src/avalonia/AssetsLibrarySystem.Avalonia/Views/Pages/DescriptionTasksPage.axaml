<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:pagevm="using:AssetsLibrarySystem.Avalonia.ViewModels"
             xmlns:models="using:AssetsLibrarySystem.Avalonia.Models"
             xmlns:appmodels="using:AssetsLibrarySystem.Application.Models"
             xmlns:lucide="clr-namespace:Lucide.Avalonia;assembly=Lucide.Avalonia"
             x:Class="AssetsLibrarySystem.Avalonia.Views.Pages.DescriptionTasksPage"
             x:DataType="pagevm:DescriptionTasksPageViewModel">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid RowDefinitions="Auto,*" RowSpacing="8">
            <Border Background="{DynamicResource AppSurfaceBrush}"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <StackPanel Spacing="4">
                        <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                   FontWeight="SemiBold"
                                   LetterSpacing="1.2"
                                   Text="描述任务" />
                        <TextBlock Foreground="{DynamicResource AppTextBrush}"
                                   FontWeight="SemiBold"
                                   Text="素材描述派发工作台" />
                        <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                   TextWrapping="Wrap"
                                   Text="左侧选范围用于描述任务派发；批量向量化则直接按当前素材库做增量更新。" />
                    </StackPanel>

                    <!-- <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center"> -->
                    <!--     <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}" -->
                    <!--                FontWeight="SemiBold" -->
                    <!--                LetterSpacing="1.2" -->
                    <!--                Text="后端状态" /> -->
                    <!--     <TextBlock Foreground="{DynamicResource AppTextBrush}" -->
                    <!--                FontWeight="SemiBold" -->
                    <!--                Text="{Binding BackendStatusTitle}" /> -->
                    <!--     <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}" -->
                    <!--                Text="{Binding BackendStatusStage}" /> -->
                    <!-- </StackPanel> -->
                </Grid>
            </Border>

            <Grid Grid.Row="1" ColumnDefinitions="320,*" ColumnSpacing="8">
                <StackPanel Spacing="8">
                    <Border Background="{DynamicResource AppSurfaceBrush}"
                            BorderBrush="{DynamicResource AppBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12">
                        <StackPanel Spacing="8">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <StackPanel Spacing="4">
                                    <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                               FontWeight="SemiBold"
                                               LetterSpacing="1.2"
                                               Text="素材库" />
                                    <TextBlock Foreground="{DynamicResource AppTextBrush}"
                                               FontWeight="SemiBold"
                                               Text="{Binding WorkspaceTitle}" />
                                    <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                               TextWrapping="Wrap"
                                               Text="{Binding WorkspaceSummary}" />
                                </StackPanel>

                                <Button Grid.Column="1"
                                        Background="{DynamicResource AppSoftSurfaceBrush}"
                                        Foreground="{DynamicResource AppTextBrush}"
                                        BorderBrush="{DynamicResource AppBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="10,8"
                                        Command="{Binding ScanSelectedLibraryCommand}"
                                        Content="扫描当前素材库" />
                            </Grid>

                            <Border Background="{DynamicResource AppSoftSurfaceBrush}"
                                    BorderBrush="{DynamicResource AppBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="8">
                                <StackPanel Spacing="4">
                                    <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                               FontWeight="SemiBold"
                                               LetterSpacing="1.2"
                                               Text="当前素材库" />
                                    <TextBlock TextWrapping="Wrap"
                                               Text="批量向量化会自动处理当前素材库里“已有描述但没有向量”以及“描述已更新、旧向量需要重建”的素材。" />
                                </StackPanel>
                            </Border>

                            <Button Background="{DynamicResource AppSoftSurfaceBrush}"
                                    Foreground="{DynamicResource AppTextBrush}"
                                    BorderBrush="{DynamicResource AppBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="10,8"
                                    Command="{Binding QueueDescriptionsForSelectionCommand}"
                                    Content="发送当前范围" />

                            <Button Background="{DynamicResource AppSoftSurfaceBrush}"
                                    Foreground="{DynamicResource AppTextBrush}"
                                    BorderBrush="{DynamicResource AppBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="10,8"
                                    Command="{Binding VectorizeSelectedDescriptionCommand}"
                                    Content="批量向量化当前素材库" />

                            <Button Background="{DynamicResource AppSoftSurfaceBrush}"
                                    Foreground="{DynamicResource AppTextBrush}"
                                    BorderBrush="{DynamicResource AppBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="10,8"
                                    Command="{Binding RebuildSearchIndexCommand}"
                                    Content="更新后端索引" />
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource AppSurfaceBrush}"
                            BorderBrush="{DynamicResource AppBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12">
                        <Grid RowDefinitions="Auto,*" RowSpacing="8">
                            <StackPanel Spacing="4">
                                <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                           FontWeight="SemiBold"
                                           LetterSpacing="1.2"
                                           Text="目录树" />
                                <TextBlock Foreground="{DynamicResource AppTextBrush}"
                                           FontWeight="SemiBold"
                                           Text="选择要发送的素材范围" />
                                <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                           TextWrapping="Wrap"
                                           Text="右键节点可直接在文件资源管理器中打开。" />
                            </StackPanel>

                            <ScrollViewer Grid.Row="1"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          MaxHeight="520">
                                <TreeView ItemsSource="{Binding AssetTreeRoots}"
                                          SelectedItem="{Binding SelectedAssetTreeNode, Mode=TwoWay}">
                                    <TreeView.Styles>
                                        <Style
                                            Selector="TreeViewItem:selected /template/ Border#PART_LayoutRoot">
                                            <Setter Property="Background" Value="Transparent" />
                                        </Style>
                                        <Style
                                            Selector="TreeViewItem:pointerover /template/ Border#PART_LayoutRoot">
                                            <Setter Property="Background" Value="Transparent" />
                                        </Style>
                                        <Style Selector="TreeViewItem">
                                            <Setter Property="Padding" Value="0" />
                                            <Setter Property="Margin" Value="0,0,0,4" />
                                        </Style>
                                    </TreeView.Styles>
                                    <TreeView.ItemTemplate>
                                        <TreeDataTemplate x:DataType="models:AssetLibraryTreeNode"
                                                          ItemsSource="{Binding Children}">
                                            <Border Background="{DynamicResource AppSoftSurfaceBrush}"
                                                    BorderBrush="{DynamicResource AppBorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="4"
                                                    Padding="8">
                                                <Border.ContextMenu>
                                                    <ContextMenu>
                                                        <MenuItem Header="在文件资源管理器中显示"
                                                                  Click="RevealInExplorer_Click"
                                                                  CommandParameter="{Binding}" />
                                                    </ContextMenu>
                                                </Border.ContextMenu>
                                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                                                    <Border Background="{DynamicResource AppAccentSurfaceBrush}"
                                                            BorderBrush="{DynamicResource AppAccentBrush}"
                                                            VerticalAlignment="Center"
                                                            BorderThickness="1"
                                                            CornerRadius="4"
                                                            Padding="4">
                                                        <lucide:LucideIcon Kind="Folder" Size="12" />
                                                    </Border>
                                                    <StackPanel Grid.Column="1" Spacing="2">
                                                        <TextBlock FontWeight="SemiBold"
                                                                   Text="{Binding DisplayName}" />
                                                        <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                                                   Text="{Binding PathLabel}" />
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="2"
                                                               Foreground="{DynamicResource AppAccentBrush}"
                                                               VerticalAlignment="Center"
                                                               Text="{Binding MetaLabel}" />
                                                </Grid>
                                            </Border>
                                        </TreeDataTemplate>
                                    </TreeView.ItemTemplate>
                                </TreeView>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </StackPanel>

                <Grid Grid.Column="1" RowDefinitions="Auto,Auto,*" RowSpacing="8">
                    <Border Background="{DynamicResource AppSurfaceBrush}"
                            BorderBrush="{DynamicResource AppBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12">
                        <StackPanel Spacing="8">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <StackPanel Spacing="4">
                                    <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                               FontWeight="SemiBold"
                                               LetterSpacing="1.2"
                                               Text="派发" />
                                    <TextBlock Foreground="{DynamicResource AppTextBrush}"
                                               FontWeight="SemiBold"
                                               Text="后端描述入口" />
                                    <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                               TextWrapping="Wrap"
                                               Text="选中单个素材时发一条；选中目录或范围时，桌面端按当前选择顺序排队。" />
                                </StackPanel>

                                <StackPanel Grid.Column="1"
                                            Spacing="4"
                                            VerticalAlignment="Center">
                                    <Button Background="{DynamicResource AppAccentBrush}"
                                            Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                                            BorderThickness="0"
                                            CornerRadius="4"
                                            Padding="10,8"
                                            Command="{Binding QueueDescriptionsForSelectionCommand}"
                                            Content="发送当前范围" />
                                    <Button Background="{DynamicResource AppSoftSurfaceBrush}"
                                            Foreground="{DynamicResource AppTextBrush}"
                                            BorderBrush="{DynamicResource AppBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            Padding="10,8"
                                            Command="{Binding QueueDescriptionCommand}"
                                            Content="仅发送当前素材" />
                                </StackPanel>
                            </Grid>

                            <Border Background="{DynamicResource AppSoftSurfaceBrush}"
                                    BorderBrush="{DynamicResource AppBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="8">
                                <TextBlock TextWrapping="Wrap"
                                           Text="{Binding DescriptionSelectionSummary}" />
                            </Border>
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="8">
                        <Border Background="{DynamicResource AppSoftSurfaceBrush}"
                                BorderBrush="{DynamicResource AppBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="8">
                            <StackPanel Spacing="4">
                                <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                           FontWeight="SemiBold"
                                           LetterSpacing="1.2"
                                           Text="当前素材" />
                                <TextBlock FontWeight="SemiBold"
                                           Text="{Binding SelectedAssetName}" />
                                <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                           TextWrapping="Wrap"
                                           Text="{Binding SelectedAssetPath}" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1"
                                Background="{DynamicResource AppSoftSurfaceBrush}"
                                BorderBrush="{DynamicResource AppBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="8">
                            <StackPanel Spacing="4">
                                <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                           FontWeight="SemiBold"
                                           LetterSpacing="1.2"
                                           Text="状态" />
                                <TextBlock Text="{Binding SelectedAssetStage}" />
                                <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                           TextWrapping="Wrap"
                                           Text="{Binding SelectedAssetAiState}" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Grid.Row="2"
                            Background="{DynamicResource AppSurfaceBrush}"
                            BorderBrush="{DynamicResource AppBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12">
                        <Grid RowDefinitions="Auto,*" RowSpacing="8">
                            <StackPanel Spacing="4">
                                <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                           FontWeight="SemiBold"
                                           LetterSpacing="1.2"
                                           Text="任务列表" />
                                <TextBlock Foreground="{DynamicResource AppTextBrush}"
                                           FontWeight="SemiBold"
                                           Text="后端描述工作队列" />
                                <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                           TextWrapping="Wrap"
                                           Text="这里只显示素材描述任务，便于追踪排队、执行、完成和失败。" />
                            </StackPanel>

                            <ScrollViewer Grid.Row="1"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{Binding DescriptionTasks}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Spacing="4" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="appmodels:BackgroundTaskEntry">
                                            <Border Background="{DynamicResource AppSoftSurfaceBrush}"
                                                    BorderBrush="{DynamicResource AppBorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="4"
                                                    Padding="8">
                                                <StackPanel Spacing="4">
                                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                        <TextBlock FontWeight="SemiBold"
                                                                   Text="{Binding StageText}" />
                                                        <Border Grid.Column="1"
                                                                Background="{DynamicResource AppAccentSurfaceBrush}"
                                                                BorderBrush="{DynamicResource AppAccentBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="4"
                                                                Padding="6,2">
                                                            <TextBlock FontSize="12"
                                                                       Text="{Binding StatusText}" />
                                                        </Border>
                                                    </Grid>
                                                    <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                                               Text="{Binding DetailText}"
                                                               TextWrapping="Wrap" />
                                                    <TextBlock FontSize="12"
                                                               Foreground="{DynamicResource AppSecondaryTextBrush}"
                                                               Text="{Binding TimelineText}" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
