<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:pagevm="using:AssetsLibrarySystem.Avalonia.ViewModels"
             xmlns:models="using:AssetsLibrarySystem.Application.Models"
             xmlns:lucide="clr-namespace:Lucide.Avalonia;assembly=Lucide.Avalonia"
             x:Class="AssetsLibrarySystem.Avalonia.Views.Pages.SettingsPage"
             x:DataType="pagevm:SettingsPageViewModel"
             FontSize="14">
    <UserControl.Styles>
        <Style Selector="Border.settings-card">
            <Setter Property="Background" Value="{DynamicResource AppSoftSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="16" />
        </Style>

        <Style Selector="Border.settings-sub-card">
            <Setter Property="Background" Value="{DynamicResource AppWindowBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="10" />
        </Style>

        <Style Selector="Button">
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="12,8" />
        </Style>

        <Style Selector="TextBlock.settings-title">
            <Setter Property="FontSize" Value="34" />
            <Setter Property="FontWeight" Value="SemiLight" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
        </Style>

        <Style Selector="TextBlock.settings-section-title">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
        </Style>
    </UserControl.Styles>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid RowDefinitions="Auto,*" RowSpacing="12" Margin="28,18,28,28">
            <Border Classes="settings-card">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <StackPanel Spacing="4">
                        <TextBlock Classes="settings-title" Text="设置" />
                        <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                   TextWrapping="Wrap"
                                   Text="管理模型网关、本地检索模型和桌面端运行状态。" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" ColumnDefinitions="320,*" ColumnSpacing="12">
                <StackPanel Spacing="12">
                    <Border Classes="settings-card">
                        <StackPanel Spacing="8">
                            <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                       FontWeight="SemiBold"
                                       Text="后端" />
                            <TextBlock Classes="settings-section-title" Text="连接信息" />
                            <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                       TextWrapping="Wrap"
                                       Text="{Binding OperatorNotice}" />

                            <Border Classes="settings-sub-card">
                                <StackPanel Spacing="4">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <lucide:LucideIcon Kind="Bot" />
                                        <TextBlock Foreground="{DynamicResource AppTextBrush}"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding BackendStatusTitle}" />
                                    </StackPanel>
                                    <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                               TextWrapping="Wrap"
                                               Text="{Binding BackendStatusDetail}" />
                                    <TextBlock Foreground="{DynamicResource AppAccentBrush}"
                                               Text="{Binding BackendEndpoint}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Classes="settings-card">
                        <StackPanel Spacing="8">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <StackPanel Spacing="4">
                                    <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                               FontWeight="SemiBold"
                                               Text="搜索模型" />
                                    <TextBlock Classes="settings-section-title"
                                               Text="{Binding SearchModelStatusTitle}" />
                                    <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                               Text="{Binding SearchModelStatusStage}" />
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Background="{DynamicResource AppSoftSurfaceBrush}"
                                        Foreground="{DynamicResource AppTextBrush}"
                                        BorderBrush="{DynamicResource AppBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="12,8"
                                        Command="{Binding RefreshModelStatusCommand}"
                                        Content="刷新状态" />
                            </Grid>

                            <Border Background="{DynamicResource AppWindowBackgroundBrush}"
                                    BorderBrush="{DynamicResource AppBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="8">
                                <TextBlock TextWrapping="Wrap"
                                           Text="{Binding SearchModelStatusDetail}" />
                            </Border>

                            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnSpacing="8" RowSpacing="4">
                                <TextBlock VerticalAlignment="Center" Text="向量来源" />
                                <ComboBox Grid.Column="1"
                                          ItemsSource="{Binding ProviderOptions}"
                                          SelectedItem="{Binding EmbeddingProvider, Mode=TwoWay}" />
                                <TextBlock Grid.Row="1" VerticalAlignment="Center" Text="向量模型" />
                                <TextBox Grid.Row="1" Grid.Column="1"
                                         Text="{Binding EmbeddingModel, Mode=TwoWay}" />
                                <TextBlock Grid.Row="2" VerticalAlignment="Center" Text="向量维度" />
                                <ComboBox Grid.Row="2" Grid.Column="1"
                                          ItemsSource="{Binding EmbeddingDimensionOptions}"
                                          SelectedItem="{Binding EmbeddingDimensions, Mode=TwoWay}" />
                                <TextBlock Grid.Row="3" VerticalAlignment="Center" Text="重排序来源" />
                                <ComboBox Grid.Row="3" Grid.Column="1"
                                          ItemsSource="{Binding ProviderOptions}"
                                          SelectedItem="{Binding RerankProvider, Mode=TwoWay}" />
                                <TextBlock Grid.Row="4" VerticalAlignment="Center" Text="重排序模型" />
                                <TextBox Grid.Row="4" Grid.Column="1"
                                         Text="{Binding RerankModel, Mode=TwoWay}" />
                            </Grid>

                            <Border Background="{DynamicResource AppWindowBackgroundBrush}"
                                    BorderBrush="{DynamicResource AppBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="8">
                                <StackPanel Spacing="6">
                                    <TextBlock Foreground="{DynamicResource AppTextBrush}"
                                               FontWeight="SemiBold"
                                               Text="检索参数" />
                                    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="8" RowSpacing="4">
                                        <TextBlock VerticalAlignment="Center" Text="候选" />
                                        <ComboBox Grid.Column="1"
                                                  ItemsSource="{Binding SearchCandidateTopKOptions}"
                                                  SelectedItem="{Binding SearchCandidateTopK, Mode=TwoWay}" />
                                        <TextBlock Grid.Row="1" VerticalAlignment="Center" Text="扩展候选" />
                                        <ComboBox Grid.Row="1" Grid.Column="1"
                                                  ItemsSource="{Binding SearchExpandedCandidateTopKOptions}"
                                                  SelectedItem="{Binding SearchExpandedCandidateTopK, Mode=TwoWay}" />
                                        <TextBlock Grid.Row="2" VerticalAlignment="Center" Text="重排" />
                                        <ComboBox Grid.Row="2" Grid.Column="1"
                                                  ItemsSource="{Binding SearchRerankTopKOptions}"
                                                  SelectedItem="{Binding SearchRerankTopK, Mode=TwoWay}" />
                                        <TextBlock Grid.Row="3" VerticalAlignment="Center" Text="Top-K" />
                                        <ComboBox Grid.Row="3" Grid.Column="1"
                                                  ItemsSource="{Binding SearchFinalTopKOptions}"
                                                  SelectedItem="{Binding SearchFinalTopK, Mode=TwoWay}" />
                                    </Grid>
                                    <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                               FontSize="12"
                                               Text="扩展候选控制向量召回数量，重排控制送入 reranker 的候选数量；数值越大通常越慢、token 越多。"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <StackPanel Spacing="4">
                                <CheckBox Content="下次启动自动预热 embedding 模型"
                                          IsChecked="{Binding AutoWarmupEmbeddingModel, Mode=TwoWay}" />
                                <CheckBox Content="下次启动自动预热 rerank 模型"
                                          IsChecked="{Binding AutoWarmupRerankModel, Mode=TwoWay}" />
                                <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                           FontSize="12"
                                           Text="DashScope 向量维度固定支持 2048 / 1024 / 512；本地 embedding 模型仍使用模型自身输出维度。"
                                           TextWrapping="Wrap" />
                                <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                           FontSize="12"
                                           Text="{Binding SettingsStatusMessage}"
                                           TextWrapping="Wrap" />
                            </StackPanel>

                            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                <Button Background="{DynamicResource AppSoftSurfaceBrush}"
                                        Foreground="{DynamicResource AppTextBrush}"
                                        BorderBrush="{DynamicResource AppBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="12,8"
                                        Command="{Binding CloseEmbeddingModelCommand}"
                                        Content="关闭 embedding" />
                                <Button Grid.Column="1"
                                        Background="{DynamicResource AppSoftSurfaceBrush}"
                                        Foreground="{DynamicResource AppTextBrush}"
                                        BorderBrush="{DynamicResource AppBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="12,8"
                                        Command="{Binding CloseRerankModelCommand}"
                                        Content="关闭 rerank" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <Grid Grid.Column="1" RowDefinitions="*,Auto" RowSpacing="12">
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <Border Classes="settings-card">
                            <StackPanel Spacing="8">
                                <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                           FontWeight="SemiBold"
                                           Text="能力清单" />
                                <TextBlock Classes="settings-section-title" Text="当前可用接口" />
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding AiCapabilities}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <VirtualizingStackPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="models:AiCapabilityRecord">
                                                <Border Classes="settings-sub-card" Margin="0,0,0,6">
                                                    <StackPanel Spacing="4">
                                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                            <TextBlock Foreground="{DynamicResource AppTextBrush}"
                                                                       FontWeight="SemiBold"
                                                                       Text="{Binding Name}" />
                                                            <TextBlock Grid.Column="1"
                                                                       Foreground="{DynamicResource AppAccentBrush}"
                                                                       Text="{Binding Endpoint}" />
                                                        </Grid>
                                                        <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                                                   TextWrapping="Wrap"
                                                                   Text="{Binding Summary}" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Classes="settings-card">
                            <StackPanel Spacing="8">
                                <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                           FontWeight="SemiBold"
                                           Text="动态" />
                                <TextBlock Classes="settings-section-title" Text="活动纪要" />
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding ActivityFeed}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <VirtualizingStackPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Classes="settings-sub-card" Margin="0,0,0,6">
                                                    <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                                               TextWrapping="Wrap"
                                                               Text="{Binding .}" />
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Grid.Row="1" Classes="settings-card">
                        <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                   TextWrapping="Wrap"
                                   Text="接口列表和活动日志保持在同一页，便于在调试时快速确认模型网关状态与操作结果。" />
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
