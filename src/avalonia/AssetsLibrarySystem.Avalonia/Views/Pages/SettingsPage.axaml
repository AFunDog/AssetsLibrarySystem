<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AssetsLibrarySystem.Avalonia.ViewModels"
             xmlns:pagevm="using:AssetsLibrarySystem.Avalonia.ViewModels"
             xmlns:models="using:AssetsLibrarySystem.Avalonia.Models"
             xmlns:lucide="clr-namespace:Lucide.Avalonia;assembly=Lucide.Avalonia"
             x:Class="AssetsLibrarySystem.Avalonia.Views.Pages.SettingsPage"
             x:DataType="pagevm:SettingsPageViewModel">
    <UserControl.Styles>
        <Style Selector="Border.page-card">
            <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12" />
        </Style>
        <Style Selector="Border.sub-card">
            <Setter Property="Background" Value="{DynamicResource AppSoftSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="8" />
        </Style>
        <Style Selector="TextBlock.eyebrow">
            <Setter Property="Foreground" Value="{DynamicResource AppSecondaryTextBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="LetterSpacing" Value="1.2" />
        </Style>
        <Style Selector="TextBlock.section-title">
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="TextBlock.section-subtitle">
            <Setter Property="Foreground" Value="{DynamicResource AppSecondaryTextBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style Selector="TextBox.prompt-box">
            <Setter Property="Background" Value="{DynamicResource AppSoftSurfaceBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="MinHeight" Value="112" />
        </Style>
        <Style Selector="Button.primary-action">
            <Setter Property="Background" Value="{DynamicResource AppAccentBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="MinHeight" Value="32" />
        </Style>
        <Style Selector="Button.secondary-action">
            <Setter Property="Background" Value="{DynamicResource AppSoftSurfaceBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="MinHeight" Value="32" />
        </Style>
    </UserControl.Styles>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid ColumnDefinitions="300,*" ColumnSpacing="8">
            <StackPanel Spacing="8">
                <Border Classes="page-card">
                    <StackPanel Spacing="4">
                        <TextBlock Classes="eyebrow" Text="设置" />
                        <TextBlock Classes="section-title" Text="模型网关与桌面配置" />
                        <TextBlock Classes="section-subtitle" Text="{Binding OperatorNotice}" />
                    </StackPanel>
                </Border>

                <Border Classes="page-card">
                    <StackPanel Spacing="8">
                        <TextBlock Classes="eyebrow" Text="后端状态" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <lucide:LucideIcon Kind="Bot" Size="18" />
                            <TextBlock Foreground="{DynamicResource AppTextBrush}"
                                       FontWeight="SemiBold"
                                       Text="{Binding BackendStatusTitle}" />
                        </StackPanel>
                        <TextBlock Classes="section-subtitle" Text="{Binding BackendStatusDetail}" />
                        <Border Classes="sub-card">
                            <TextBlock Foreground="{DynamicResource AppAccentBrush}" Text="{Binding BackendEndpoint}" />
                        </Border>
                    </StackPanel>
                </Border>

                <Border Classes="page-card">
                    <StackPanel Spacing="8">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                            <StackPanel Spacing="4">
                                <TextBlock Classes="eyebrow" Text="本地搜索模型" />
                                <TextBlock Classes="section-title" Text="{Binding SearchModelStatusTitle}" />
                                <TextBlock Classes="section-subtitle" Text="{Binding SearchModelStatusStage}" />
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Classes="secondary-action"
                                    Command="{Binding RefreshModelStatusCommand}"
                                    Content="刷新状态" />
                        </Grid>

                        <TextBlock Classes="section-subtitle" Text="{Binding SearchModelStatusDetail}" />

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                            <Button Classes="secondary-action"
                                    Command="{Binding CloseEmbeddingModelCommand}"
                                    Content="关闭 embedding" />
                            <Button Grid.Column="1"
                                    Classes="secondary-action"
                                    Command="{Binding CloseRerankModelCommand}"
                                    Content="关闭 rerank" />
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>

            <Grid Grid.Column="1" RowDefinitions="Auto,*" RowSpacing="8">
                <Border Classes="page-card">
                    <StackPanel Spacing="8">
                        <TextBlock Classes="eyebrow" Text="提示词" />
                        <TextBlock Classes="section-title" Text="发送给模型网关的草稿" />
                        <TextBox Classes="prompt-box"
                                 Text="{Binding PromptDraft}"
                                 AcceptsReturn="True"
                                 VerticalContentAlignment="Top" />
                        <Button Classes="primary-action"
                                Command="{Binding SubmitPromptCommand}"
                                Content="准备发送提示词" />
                    </StackPanel>
                </Border>

                <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="8">
                    <Border Classes="page-card">
                        <StackPanel Spacing="8">
                            <TextBlock Classes="eyebrow" Text="能力清单" />
                            <TextBlock Classes="section-title" Text="当前可用接口" />
                            <ItemsControl ItemsSource="{Binding AiCapabilities}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="models:AiCapabilityRecord">
                                        <Border Classes="sub-card" Margin="0,0,0,4">
                                            <StackPanel Spacing="4">
                                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                    <TextBlock Foreground="{DynamicResource AppTextBrush}"
                                                               FontWeight="SemiBold"
                                                               Text="{Binding Name}" />
                                                    <TextBlock Grid.Column="1"
                                                               Foreground="{DynamicResource AppAccentBrush}"
                                                               Text="{Binding Endpoint}" />
                                                </Grid>
                                                <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                                           TextWrapping="Wrap"
                                                           Text="{Binding Summary}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Classes="page-card">
                        <StackPanel Spacing="8">
                            <TextBlock Classes="eyebrow" Text="动态" />
                            <TextBlock Classes="section-title" Text="活动纪要" />
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Height="420">
                                <ItemsControl ItemsSource="{Binding ActivityFeed}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Classes="sub-card" Margin="0,0,0,4">
                                                <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                                           TextWrapping="Wrap"
                                                           Text="{Binding .}" />
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
