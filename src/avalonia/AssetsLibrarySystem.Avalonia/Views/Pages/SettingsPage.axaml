<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:pagevm="using:AssetsLibrarySystem.Avalonia.ViewModels"
             xmlns:models="using:AssetsLibrarySystem.Application.Models"
             xmlns:lucide="clr-namespace:Lucide.Avalonia;assembly=Lucide.Avalonia"
             x:Class="AssetsLibrarySystem.Avalonia.Views.Pages.SettingsPage"
             x:DataType="pagevm:SettingsPageViewModel">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid RowDefinitions="Auto,*" RowSpacing="8">
            <Border Background="{DynamicResource AppSurfaceBrush}"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <StackPanel Spacing="4">
                        <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                   FontWeight="SemiBold"
                                   LetterSpacing="1.2"
                                   Text="设置" />
                        <TextBlock Foreground="{DynamicResource AppTextBrush}"
                                   FontWeight="SemiBold"
                                   Text="模型网关与桌面配置" />
                        <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                   TextWrapping="Wrap"
                                   Text="这里集中管理后端连接、本地搜索模型和发送给模型网关的提示词草稿。" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" ColumnDefinitions="300,*" ColumnSpacing="8">
                <StackPanel Spacing="8">
                    <Border Background="{DynamicResource AppSurfaceBrush}"
                            BorderBrush="{DynamicResource AppBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12">
                        <StackPanel Spacing="8">
                            <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                       FontWeight="SemiBold"
                                       LetterSpacing="1.2"
                                       Text="后端" />
                            <TextBlock Foreground="{DynamicResource AppTextBrush}"
                                       FontWeight="SemiBold"
                                       Text="连接信息" />
                            <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                       TextWrapping="Wrap"
                                       Text="{Binding OperatorNotice}" />

                            <Border Background="{DynamicResource AppSoftSurfaceBrush}"
                                    BorderBrush="{DynamicResource AppBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="8">
                                <StackPanel Spacing="4">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <lucide:LucideIcon Kind="Bot" />
                                        <TextBlock Foreground="{DynamicResource AppTextBrush}"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding BackendStatusTitle}" />
                                    </StackPanel>
                                    <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                               TextWrapping="Wrap"
                                               Text="{Binding BackendStatusDetail}" />
                                    <TextBlock Foreground="{DynamicResource AppAccentBrush}"
                                               Text="{Binding BackendEndpoint}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource AppSurfaceBrush}"
                            BorderBrush="{DynamicResource AppBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12">
                        <StackPanel Spacing="8">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <StackPanel Spacing="4">
                                    <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                               FontWeight="SemiBold"
                                               LetterSpacing="1.2"
                                               Text="搜索模型" />
                                    <TextBlock Foreground="{DynamicResource AppTextBrush}"
                                               FontWeight="SemiBold"
                                               Text="{Binding SearchModelStatusTitle}" />
                                    <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                               Text="{Binding SearchModelStatusStage}" />
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Background="{DynamicResource AppSoftSurfaceBrush}"
                                        Foreground="{DynamicResource AppTextBrush}"
                                        BorderBrush="{DynamicResource AppBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="10,8"
                                        Command="{Binding RefreshModelStatusCommand}"
                                        Content="刷新状态" />
                            </Grid>

                            <Border Background="{DynamicResource AppSoftSurfaceBrush}"
                                    BorderBrush="{DynamicResource AppBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="8">
                                <TextBlock TextWrapping="Wrap"
                                           Text="{Binding SearchModelStatusDetail}" />
                            </Border>

                            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnSpacing="8" RowSpacing="4">
                                <TextBlock VerticalAlignment="Center" Text="向量来源" />
                                <ComboBox Grid.Column="1"
                                          ItemsSource="{Binding ProviderOptions}"
                                          SelectedItem="{Binding EmbeddingProvider, Mode=TwoWay}" />
                                <TextBlock Grid.Row="1" VerticalAlignment="Center" Text="向量模型" />
                                <TextBox Grid.Row="1" Grid.Column="1"
                                         Text="{Binding EmbeddingModel, Mode=TwoWay}" />
                                <TextBlock Grid.Row="2" VerticalAlignment="Center" Text="向量维度" />
                                <ComboBox Grid.Row="2" Grid.Column="1"
                                          ItemsSource="{Binding EmbeddingDimensionOptions}"
                                          SelectedItem="{Binding EmbeddingDimensions, Mode=TwoWay}" />
                                <TextBlock Grid.Row="3" VerticalAlignment="Center" Text="重排序来源" />
                                <ComboBox Grid.Row="3" Grid.Column="1"
                                          ItemsSource="{Binding ProviderOptions}"
                                          SelectedItem="{Binding RerankProvider, Mode=TwoWay}" />
                                <TextBlock Grid.Row="4" VerticalAlignment="Center" Text="重排序模型" />
                                <TextBox Grid.Row="4" Grid.Column="1"
                                         Text="{Binding RerankModel, Mode=TwoWay}" />
                            </Grid>

                            <Border Background="{DynamicResource AppSoftSurfaceBrush}"
                                    BorderBrush="{DynamicResource AppBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="8">
                                <StackPanel Spacing="6">
                                    <TextBlock Foreground="{DynamicResource AppTextBrush}"
                                               FontWeight="SemiBold"
                                               Text="检索参数" />
                                    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="8" RowSpacing="4">
                                        <TextBlock VerticalAlignment="Center" Text="候选" />
                                        <ComboBox Grid.Column="1"
                                                  ItemsSource="{Binding SearchCandidateTopKOptions}"
                                                  SelectedItem="{Binding SearchCandidateTopK, Mode=TwoWay}" />
                                        <TextBlock Grid.Row="1" VerticalAlignment="Center" Text="扩展候选" />
                                        <ComboBox Grid.Row="1" Grid.Column="1"
                                                  ItemsSource="{Binding SearchExpandedCandidateTopKOptions}"
                                                  SelectedItem="{Binding SearchExpandedCandidateTopK, Mode=TwoWay}" />
                                        <TextBlock Grid.Row="2" VerticalAlignment="Center" Text="重排" />
                                        <ComboBox Grid.Row="2" Grid.Column="1"
                                                  ItemsSource="{Binding SearchRerankTopKOptions}"
                                                  SelectedItem="{Binding SearchRerankTopK, Mode=TwoWay}" />
                                        <TextBlock Grid.Row="3" VerticalAlignment="Center" Text="Top-K" />
                                        <ComboBox Grid.Row="3" Grid.Column="1"
                                                  ItemsSource="{Binding SearchFinalTopKOptions}"
                                                  SelectedItem="{Binding SearchFinalTopK, Mode=TwoWay}" />
                                    </Grid>
                                    <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                               FontSize="12"
                                               Text="扩展候选控制向量召回数量，重排控制送入 reranker 的候选数量；数值越大通常越慢、token 越多。"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <StackPanel Spacing="4">
                                <CheckBox Content="下次启动自动预热 embedding 模型"
                                          IsChecked="{Binding AutoWarmupEmbeddingModel, Mode=TwoWay}" />
                                <CheckBox Content="下次启动自动预热 rerank 模型"
                                          IsChecked="{Binding AutoWarmupRerankModel, Mode=TwoWay}" />
                                <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                           FontSize="12"
                                           Text="DashScope 向量维度固定支持 2048 / 1024 / 512；本地 embedding 模型仍使用模型自身输出维度。"
                                           TextWrapping="Wrap" />
                                <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                           FontSize="12"
                                           Text="{Binding SettingsStatusMessage}"
                                           TextWrapping="Wrap" />
                            </StackPanel>

                            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                <Button Background="{DynamicResource AppSoftSurfaceBrush}"
                                        Foreground="{DynamicResource AppTextBrush}"
                                        BorderBrush="{DynamicResource AppBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="10,8"
                                        Command="{Binding CloseEmbeddingModelCommand}"
                                        Content="关闭 embedding" />
                                <Button Grid.Column="1"
                                        Background="{DynamicResource AppSoftSurfaceBrush}"
                                        Foreground="{DynamicResource AppTextBrush}"
                                        BorderBrush="{DynamicResource AppBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="10,8"
                                        Command="{Binding CloseRerankModelCommand}"
                                        Content="关闭 rerank" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <Grid Grid.Column="1" RowDefinitions="Auto,*,Auto" RowSpacing="8">
                    <Border Background="{DynamicResource AppSurfaceBrush}"
                            BorderBrush="{DynamicResource AppBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12">
                        <StackPanel Spacing="8">
                            <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                       FontWeight="SemiBold"
                                       LetterSpacing="1.2"
                                       Text="提示词" />
                            <TextBlock Foreground="{DynamicResource AppTextBrush}"
                                       FontWeight="SemiBold"
                                       Text="发送给模型网关的草稿" />
                            <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                       TextWrapping="Wrap"
                                       Text="这里仅保存当前会话草稿，真正发送仍由后端接口接管。" />
                            <TextBox Background="{DynamicResource AppSoftSurfaceBrush}"
                                     Foreground="{DynamicResource AppTextBrush}"
                                     BorderBrush="{DynamicResource AppBorderBrush}"
                                     CornerRadius="4"
                                     TextWrapping="Wrap"
                                     MinHeight="112"
                                     Text="{Binding PromptDraft}"
                                     AcceptsReturn="True"
                                     VerticalContentAlignment="Top" />
                            <Button Background="{DynamicResource AppAccentBrush}"
                                    Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                                    BorderThickness="0"
                                    CornerRadius="4"
                                    Padding="10,8"
                                    MinHeight="32"
                                    Command="{Binding SubmitPromptCommand}"
                                    Content="准备发送提示词" />
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="8">
                        <Border Background="{DynamicResource AppSurfaceBrush}"
                                BorderBrush="{DynamicResource AppBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12">
                            <StackPanel Spacing="8">
                                <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                           FontWeight="SemiBold"
                                           LetterSpacing="1.2"
                                           Text="能力清单" />
                                <TextBlock Foreground="{DynamicResource AppTextBrush}"
                                           FontWeight="SemiBold"
                                           Text="当前可用接口" />
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding AiCapabilities}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <VirtualizingStackPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="models:AiCapabilityRecord">
                                                <Border Background="{DynamicResource AppSoftSurfaceBrush}"
                                                        BorderBrush="{DynamicResource AppBorderBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="4"
                                                        Padding="8"
                                                        Margin="0,0,0,4">
                                                    <StackPanel Spacing="4">
                                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                            <TextBlock Foreground="{DynamicResource AppTextBrush}"
                                                                       FontWeight="SemiBold"
                                                                       Text="{Binding Name}" />
                                                            <TextBlock Grid.Column="1"
                                                                       Foreground="{DynamicResource AppAccentBrush}"
                                                                       Text="{Binding Endpoint}" />
                                                        </Grid>
                                                        <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                                                   TextWrapping="Wrap"
                                                                   Text="{Binding Summary}" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1"
                                Background="{DynamicResource AppSurfaceBrush}"
                                BorderBrush="{DynamicResource AppBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12">
                            <StackPanel Spacing="8">
                                <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                           FontWeight="SemiBold"
                                           LetterSpacing="1.2"
                                           Text="动态" />
                                <TextBlock Foreground="{DynamicResource AppTextBrush}"
                                           FontWeight="SemiBold"
                                           Text="活动纪要" />
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding ActivityFeed}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <VirtualizingStackPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{DynamicResource AppSoftSurfaceBrush}"
                                                        BorderBrush="{DynamicResource AppBorderBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="4"
                                                        Padding="8"
                                                        Margin="0,0,0,4">
                                                    <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                                               TextWrapping="Wrap"
                                                               Text="{Binding .}" />
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Grid.Row="2"
                            Background="{DynamicResource AppSurfaceBrush}"
                            BorderBrush="{DynamicResource AppBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12">
                        <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                   TextWrapping="Wrap"
                                   Text="提示词、接口列表和活动日志保持在同一页，便于在调试时快速确认状态与操作结果。" />
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
