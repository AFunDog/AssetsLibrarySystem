<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AssetsLibrarySystem.Avalonia.ViewModels"
             xmlns:models="using:AssetsLibrarySystem.Avalonia.Models"
             xmlns:lucide="clr-namespace:Lucide.Avalonia;assembly=Lucide.Avalonia"
             x:Class="AssetsLibrarySystem.Avalonia.Views.Pages.LibraryPage"
             x:DataType="vm:MainWindowViewModel">
    
    <Design.DataContext>
        <vm:MainWindowViewModel BackendStatusTitle="设计时模式"
                                BackendStatusDetail="当前展示的是页面内定义的设计时素材树。"
                                WorkspaceTitle="DDLC_PLUS"
                                WorkspaceSummary="D:\Data\全资源\music\DDLC\DDLC_PLUS"
                                AssetSummary="已展开目录，便于直接调整树节点间距、文字密度和徽标布局。"
                                OperatorNotice="设计时数据写在 LibraryPage.axaml 的 Design.DataContext 中。"
                                PromptDraft="请围绕当前素材生成更适合检索的中文描述。"
                                SelectedAssetName="1.wav"
                                SelectedAssetLibrary="music"
                                SelectedAssetPath="D:\Data\全资源\music\DDLC\DDLC_PLUS\1.wav"
                                SelectedAssetType="音频"
                                SelectedAssetStage="已扫描"
                                SelectedAssetAiState="已标注"
                                SelectedAssetDetail="音频文件 · 2.1 MB · 修改于 2026-05-13 09:15">
            <vm:MainWindowViewModel.Libraries>
                <models:LibraryWorkspace Id="lib-music"
                                         Name="music"
                                         RootPath="D:\Data\全资源\music"
                                         Summary="已扫描 615 个素材文件，可在树中继续展开目录。"
                                         SyncMode="已扫描"
                                         AssetCount="615" />
                <models:LibraryWorkspace Id="lib-illustration"
                                         Name="illustration"
                                         RootPath="D:\Assets\Illustrations"
                                         Summary="已扫描 248 个插画与参考图像。"
                                         SyncMode="已扫描"
                                         AssetCount="248" />
            </vm:MainWindowViewModel.Libraries>
            <vm:MainWindowViewModel.SelectedLibrary>
                <models:LibraryWorkspace Id="lib-music"
                                         Name="music"
                                         RootPath="D:\Data\全资源\music"
                                         Summary="已扫描 615 个素材文件，可在树中继续展开目录。"
                                         SyncMode="已扫描"
                                         AssetCount="615" />
            </vm:MainWindowViewModel.SelectedLibrary>
            <vm:MainWindowViewModel.SelectedAsset>
                <models:ManagedAssetRecord Id="asset-002"
                                           Name="1.wav"
                                           LibraryName="music"
                                           AssetType="音频"
                                           RelativePath="DDLC\DDLC_PLUS\1.wav"
                                           LocalPath="D:\Data\全资源\music\DDLC\DDLC_PLUS\1.wav"
                                           Summary="音频文件 · 2.1 MB · 修改于 2026-05-13 09:15"
                                           Stage="已扫描"
                                           AiState="已标注" />
            </vm:MainWindowViewModel.SelectedAsset>
            <vm:MainWindowViewModel.SelectedAssetTreeNode>
                <models:AssetLibraryTreeNode DisplayName="1.wav"
                                             MetaLabel="音频"
                                             CategorySummary="已扫描"
                                             TypeLabel="音频"
                                             StatusLabel="已扫描"
                                             PathLabel="DDLC\DDLC_PLUS\1.wav"
                                             Summary="音频文件 · 2.1 MB · 修改于 2026-05-13 09:15"
                                             FullPath="D:\Data\全资源\music\DDLC\DDLC_PLUS\1.wav"
                                             Kind="File">
                    <models:AssetLibraryTreeNode.Asset>
                        <models:ManagedAssetRecord Id="asset-002"
                                                   Name="1.wav"
                                                   LibraryName="music"
                                                   AssetType="音频"
                                                   RelativePath="DDLC\DDLC_PLUS\1.wav"
                                                   LocalPath="D:\Data\全资源\music\DDLC\DDLC_PLUS\1.wav"
                                                   Summary="音频文件 · 2.1 MB · 修改于 2026-05-13 09:15"
                                                   Stage="已扫描"
                                                   AiState="已标注" />
                    </models:AssetLibraryTreeNode.Asset>
                </models:AssetLibraryTreeNode>
            </vm:MainWindowViewModel.SelectedAssetTreeNode>
            <vm:MainWindowViewModel.SelectedAssetTags>
                <x:String>音频</x:String>
                <x:String>wav</x:String>
                <x:String>环境音</x:String>
            </vm:MainWindowViewModel.SelectedAssetTags>
            <vm:MainWindowViewModel.AssetTreeRoots>
                <models:AssetLibraryTreeNode DisplayName="music"
                                             MetaLabel="615 项"
                                             CategorySummary="视频 / 音频"
                                             TypeLabel="素材库"
                                             StatusLabel="已扫描"
                                             PathLabel="D:\Data\全资源\music"
                                             Summary="已扫描 615 个素材文件，可在树中继续展开目录。"
                                             FullPath="D:\Data\全资源\music"
                                             Kind="Library">
                    <models:AssetLibraryTreeNode.Children>
                        <models:AssetLibraryTreeNode DisplayName="DDLC"
                                                     MetaLabel="102 项"
                                                     CategorySummary="音频"
                                                     TypeLabel="目录"
                                                     StatusLabel=""
                                                     PathLabel="DDLC"
                                                     Summary="目录 · DDLC"
                                                     FullPath="D:\Data\全资源\music\DDLC"
                                                     Kind="Directory">
                            <models:AssetLibraryTreeNode.Children>
                                <models:AssetLibraryTreeNode DisplayName="Boki Boki Literature Club!! .mp3"
                                                             MetaLabel="音频"
                                                             CategorySummary="已扫描"
                                                             TypeLabel="音频"
                                                             StatusLabel="已扫描"
                                                             PathLabel="DDLC\Boki Boki Literature Club!! .mp3"
                                                             Summary="音频文件 · 8.4 MB · 修改于 2026-05-12 19:42"
                                                             FullPath="D:\Data\全资源\music\DDLC\Boki Boki Literature Club!! .mp3"
                                                             Kind="File" />
                                <models:AssetLibraryTreeNode DisplayName="DDLC_PLUS"
                                                             MetaLabel="85 项"
                                                             CategorySummary="音频"
                                                             TypeLabel="目录"
                                                             StatusLabel=""
                                                             PathLabel="DDLC\DDLC_PLUS"
                                                             Summary="目录 · DDLC\DDLC_PLUS"
                                                             FullPath="D:\Data\全资源\music\DDLC\DDLC_PLUS"
                                                             Kind="Directory">
                                    <models:AssetLibraryTreeNode.Children>
                                        <models:AssetLibraryTreeNode DisplayName="1.wav"
                                                                     MetaLabel="音频"
                                                                     CategorySummary="已扫描"
                                                                     TypeLabel="音频"
                                                                     StatusLabel="已扫描"
                                                                     PathLabel="DDLC\DDLC_PLUS\1.wav"
                                                                     Summary="音频文件 · 2.1 MB · 修改于 2026-05-13 09:15"
                                                                     FullPath="D:\Data\全资源\music\DDLC\DDLC_PLUS\1.wav"
                                                                     Kind="File">
                                            <models:AssetLibraryTreeNode.Asset>
                                                <models:ManagedAssetRecord Id="asset-002"
                                                                           Name="1.wav"
                                                                           LibraryName="music"
                                                                           AssetType="音频"
                                                                           RelativePath="DDLC\DDLC_PLUS\1.wav"
                                                                           LocalPath="D:\Data\全资源\music\DDLC\DDLC_PLUS\1.wav"
                                                                           Summary="音频文件 · 2.1 MB · 修改于 2026-05-13 09:15"
                                                                           Stage="已扫描"
                                                                           AiState="已标注" />
                                            </models:AssetLibraryTreeNode.Asset>
                                        </models:AssetLibraryTreeNode>
                                        <models:AssetLibraryTreeNode DisplayName="10-yuri.wav"
                                                                     MetaLabel="音频"
                                                                     CategorySummary="已扫描"
                                                                     TypeLabel="音频"
                                                                     StatusLabel="已扫描"
                                                                     PathLabel="DDLC\DDLC_PLUS\10-yuri.wav"
                                                                     Summary="音频文件 · 2.4 MB · 修改于 2026-05-13 09:16"
                                                                     FullPath="D:\Data\全资源\music\DDLC\DDLC_PLUS\10-yuri.wav"
                                                                     Kind="File" />
                                    </models:AssetLibraryTreeNode.Children>
                                </models:AssetLibraryTreeNode>
                            </models:AssetLibraryTreeNode.Children>
                        </models:AssetLibraryTreeNode>
                    </models:AssetLibraryTreeNode.Children>
                </models:AssetLibraryTreeNode>
                <models:AssetLibraryTreeNode DisplayName="illustration"
                                             MetaLabel="248 项"
                                             CategorySummary="图片 / 视频"
                                             TypeLabel="素材库"
                                             StatusLabel="已扫描"
                                             PathLabel="D:\Assets\Illustrations"
                                             Summary="已扫描 248 个插画与参考图像。"
                                             FullPath="D:\Assets\Illustrations"
                                             Kind="Library" />
            </vm:MainWindowViewModel.AssetTreeRoots>
            <vm:MainWindowViewModel.ActivityFeed>
                <x:String>设计时数据写在页面内，便于单独调整树节点模板。</x:String>
                <x:String>树节点当前是单行布局，展示数量、类型和状态。</x:String>
                <x:String>默认选中样式已覆盖，只保留自定义节点高亮。</x:String>
            </vm:MainWindowViewModel.ActivityFeed>
        </vm:MainWindowViewModel>
    </Design.DataContext>
    <UserControl.Styles>
        <Style Selector="Border.surface">
            <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="20" />
            <Setter Property="Padding" Value="20" />
        </Style>
        <Style Selector="Border.soft-surface">
            <Setter Property="Background" Value="{DynamicResource AppSoftSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Padding" Value="14" />
        </Style>
        <Style Selector="TextBlock.eyebrow">
            <Setter Property="Foreground" Value="{DynamicResource AppSecondaryTextBrush}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="LetterSpacing" Value="1.4" />
        </Style>
        <Style Selector="TextBlock.section-title">
            <Setter Property="FontSize" Value="19" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
        </Style>
        <Style Selector="TextBlock.section-subtitle">
            <Setter Property="Foreground" Value="{DynamicResource AppSecondaryTextBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style Selector="TreeView.asset-tree">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
        </Style>
        <Style Selector="TreeView.asset-tree TreeViewItem /template/ Border#PART_LayoutRoot">
            <Setter Property="Background"  Value="{x:Null}"></Setter>
        </Style>
        <Style Selector="TreeView.asset-tree TreeViewItem /template/ ToggleButton">
            <Setter Property="Width" Value="18" />
            <Setter Property="Height" Value="18" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,2,6,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style Selector="Border.tree-node-surface">
            <Setter Property="Background" Value="{DynamicResource AppSoftSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="10,6" />
        </Style>
        <Style Selector="TreeViewItem:selected Border.tree-node-surface">
            <Setter Property="Background" Value="{DynamicResource AppAccentSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBrush}" />
        </Style>
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="{DynamicResource AppAccentBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="14,9" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style Selector="Button.secondary">
            <Setter Property="Background" Value="{DynamicResource AppSoftSurfaceBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="14,9" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="Border.tag-chip">
            <Setter Property="Background" Value="{DynamicResource AppAccentSurfaceBrush}" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Margin" Value="0,0,8,8" />
        </Style>
    </UserControl.Styles>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid ColumnDefinitions="340,*" ColumnSpacing="20">
            <Border Classes="surface">
                <StackPanel Spacing="16">
                    <StackPanel Spacing="4">
                        <TextBlock Classes="eyebrow" Text="Local Libraries" />
                        <TextBlock Classes="section-title" Text="素材库导航" />
                        <TextBlock Classes="section-subtitle" Text="登记本地文件夹为素材库目录，再扫描并展示文本、图片、视频和音频文件。" />
                    </StackPanel>

                    <Grid ColumnDefinitions="Auto,Auto,*" ColumnSpacing="10">
                        <Button Classes="primary" Click="AddLibraryFolder_Click" Content="添加素材库目录" />
                        <Button Grid.Column="1" Classes="secondary" Command="{Binding ScanSelectedLibraryCommand}" Content="扫描当前素材库" />
                    </Grid>

                    <Border Classes="soft-surface">
                        <StackPanel Spacing="10">
                            <TextBlock FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppTextBrush}"
                                       Text="{Binding SelectedLibrary.Name, FallbackValue=尚未选择素材库}" />
                            <TextBlock Classes="section-subtitle"
                                       Text="{Binding SelectedLibrary.RootPath, FallbackValue=请先添加一个素材库目录。}" />
                            <TextBlock Foreground="{DynamicResource AppMutedTextBrush}"
                                       TextWrapping="Wrap"
                                       Text="{Binding SelectedLibrary.Summary, FallbackValue=树状视图会按素材库、目录和文件展示扫描结果。}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Classes="surface">
                <Grid RowDefinitions="Auto,Auto,*" RowSpacing="16">
                    <StackPanel Spacing="4">
                        <TextBlock Classes="eyebrow" Text="Asset Queue" />
                        <TextBlock Classes="section-title" MinHeight="26" Text="{Binding WorkspaceTitle}" />
                        <TextBlock Classes="section-subtitle" Text="{Binding WorkspaceSummary}" />
                    </StackPanel>

                    <Border Grid.Row="1" Classes="soft-surface">
                        <TextBlock Foreground="{DynamicResource AppMutedTextBrush}" TextWrapping="Wrap" Text="{Binding AssetSummary}" />
                    </Border>

                    <Grid Grid.Row="2" ColumnDefinitions="*,320" ColumnSpacing="16">
                        <TreeView Classes="asset-tree"
                                  AutoScrollToSelectedItem="True"
                                  ItemsSource="{Binding AssetTreeRoots}"
                                  SelectedItem="{Binding SelectedAssetTreeNode, Mode=TwoWay}">
                            <TreeView.ItemTemplate>
                                <TreeDataTemplate x:DataType="models:AssetLibraryTreeNode"
                                                  ItemsSource="{Binding Children}">
                                    <Border Classes="tree-node-surface">
                                        <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto" ColumnSpacing="8">
                                            <Border Width="22"
                                                    Height="22"
                                                    Background="{DynamicResource AppBadgeBrush}"
                                                    CornerRadius="999"
                                                    VerticalAlignment="Center">
                                                <lucide:LucideIcon HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   Size="14"
                                                                   Kind="FolderTree" />
                                            </Border>
                                            <TextBlock Grid.Column="1"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"
                                                       Foreground="{DynamicResource AppTextBrush}"
                                                       Text="{Binding DisplayName}" />
                                            <TextBlock Grid.Column="2"
                                                       FontSize="11"
                                                       VerticalAlignment="Center"
                                                       Foreground="{DynamicResource AppSecondaryTextBrush}"
                                                       Text="{Binding MetaLabel}" />
                                            <Border Grid.Column="3"
                                                    Background="{DynamicResource AppBadgeBrush}"
                                                    CornerRadius="999"
                                                    Padding="8,3"
                                                    HorizontalAlignment="Right">
                                                <TextBlock FontSize="11"
                                                           Foreground="{DynamicResource AppAccentBrush}"
                                                           Text="{Binding CategorySummary}" />
                                            </Border>
                                            <TextBlock Grid.Column="4"
                                                       HorizontalAlignment="Right"
                                                       VerticalAlignment="Center"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource AppSecondaryTextBrush}"
                                                       Text="{Binding StatusLabel}" />
                                        </Grid>
                                    </Border>
                                </TreeDataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>

                        <StackPanel Grid.Column="1" Spacing="14">
                            <Border Classes="soft-surface">
                                <StackPanel Spacing="12">
                                    <TextBlock Classes="eyebrow" Text="Selected Asset" />
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <lucide:LucideIcon HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Size="18"
                                                           Kind="FileText" />
                                        <TextBlock Classes="section-title"
                                                   FontSize="18"
                                                   Text="{Binding SelectedAssetName}" />
                                    </StackPanel>
                                    <TextBlock Foreground="{DynamicResource AppAccentBrush}"
                                               Text="{Binding SelectedAssetLibrary}" />
                                    <TextBlock Classes="section-subtitle"
                                               Text="{Binding SelectedAssetPath}" />

                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10" RowDefinitions="Auto,Auto">
                                        <Border Classes="soft-surface">
                                            <StackPanel Spacing="4">
                                                <TextBlock Classes="eyebrow" Text="Type" />
                                                <TextBlock Foreground="{DynamicResource AppTextBrush}"
                                                           Text="{Binding SelectedAssetType}" />
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Column="1" Classes="soft-surface">
                                            <StackPanel Spacing="4">
                                                <TextBlock Classes="eyebrow" Text="Stage" />
                                                <TextBlock Foreground="{DynamicResource AppTextBrush}"
                                                           Text="{Binding SelectedAssetStage}" />
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Row="1" Classes="soft-surface" Grid.ColumnSpan="2">
                                            <StackPanel Spacing="4">
                                                <TextBlock Classes="eyebrow" Text="AI State" />
                                                <TextBlock Foreground="{DynamicResource AppTextBrush}"
                                                           Text="{Binding SelectedAssetAiState}" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <Border Classes="soft-surface">
                                        <TextBlock Foreground="{DynamicResource AppMutedTextBrush}"
                                                   TextWrapping="Wrap"
                                                   Text="{Binding SelectedAssetDetail}" />
                                    </Border>

                                    <ItemsControl ItemsSource="{Binding SelectedAssetTags}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Classes="tag-chip">
                                                    <TextBlock Foreground="{DynamicResource AppAccentBrush}"
                                                               Text="{Binding .}" />
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <Border Classes="soft-surface">
                                <StackPanel Spacing="12">
                                    <TextBlock Classes="eyebrow" Text="Actions" />
                                    <TextBlock Classes="section-title" FontSize="18" Text="素材操作" />
                                    <TextBlock Classes="section-subtitle"
                                               Text="保留当前占位交互，后续再接真实目录扫描、描述任务和索引流水线。" />
                                    <Button Classes="primary"
                                            Command="{Binding QueueDescriptionCommand}"
                                            Content="排入描述任务" />
                                    <Button Classes="secondary"
                                            Command="{Binding QueueEmbeddingCommand}"
                                            Content="排入索引任务" />
                                    <Button Classes="secondary"
                                            Command="{Binding MarkManagedCommand}"
                                            Content="标记为 .NET 已接管" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
