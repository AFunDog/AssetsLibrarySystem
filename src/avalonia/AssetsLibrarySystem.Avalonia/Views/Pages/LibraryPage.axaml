<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AssetsLibrarySystem.Avalonia.ViewModels"
             xmlns:models="using:AssetsLibrarySystem.Avalonia.Models"
             xmlns:lucide="clr-namespace:Lucide.Avalonia;assembly=Lucide.Avalonia"
             x:Class="AssetsLibrarySystem.Avalonia.Views.Pages.LibraryPage"
             x:DataType="vm:MainWindowViewModel">
    <UserControl.Styles>
        <Style Selector="Border.surface">
            <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="20" />
            <Setter Property="Padding" Value="20" />
        </Style>
        <Style Selector="Border.soft-surface">
            <Setter Property="Background" Value="{DynamicResource AppSoftSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Padding" Value="14" />
        </Style>
        <Style Selector="TextBlock.eyebrow">
            <Setter Property="Foreground" Value="{DynamicResource AppSecondaryTextBrush}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="LetterSpacing" Value="1.4" />
        </Style>
        <Style Selector="TextBlock.section-title">
            <Setter Property="FontSize" Value="19" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
        </Style>
        <Style Selector="TextBlock.section-subtitle">
            <Setter Property="Foreground" Value="{DynamicResource AppSecondaryTextBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style Selector="TreeView.asset-tree">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
        </Style>
        <Style Selector="TreeView.asset-tree TreeViewItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,2" />
            <Setter Property="MinHeight" Value="0" />
        </Style>
        <Style Selector="TreeView.asset-tree TreeViewItem:pointerover">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="TreeView.asset-tree TreeViewItem:selected">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="TreeView.asset-tree TreeViewItem:pointerover /template/ ContentPresenter#PART_HeaderPresenter">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="TreeView.asset-tree TreeViewItem:selected /template/ ContentPresenter#PART_HeaderPresenter">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
        </Style>
        <Style Selector="TreeView.asset-tree TreeViewItem:selected:pointerover /template/ ContentPresenter#PART_HeaderPresenter">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
        </Style>
        <Style Selector="TreeView.asset-tree TreeViewItem /template/ Grid#PART_Header">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="MinHeight" Value="0" />
        </Style>
        <Style Selector="TreeView.asset-tree TreeViewItem /template/ ToggleButton">
            <Setter Property="Width" Value="18" />
            <Setter Property="Height" Value="18" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,2,6,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style Selector="Border.tree-node-surface">
            <Setter Property="Background" Value="{DynamicResource AppSoftSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="10,6" />
        </Style>
        <Style Selector="TreeViewItem:selected Border.tree-node-surface">
            <Setter Property="Background" Value="{DynamicResource AppAccentSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBrush}" />
        </Style>
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="{DynamicResource AppAccentBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="14,9" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style Selector="Button.secondary">
            <Setter Property="Background" Value="{DynamicResource AppSoftSurfaceBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="14,9" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </UserControl.Styles>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid ColumnDefinitions="340,*" ColumnSpacing="20">
            <Border Classes="surface">
                <StackPanel Spacing="16">
                    <StackPanel Spacing="4">
                        <TextBlock Classes="eyebrow" Text="Local Libraries" />
                        <TextBlock Classes="section-title" Text="素材库导航" />
                        <TextBlock Classes="section-subtitle" Text="登记本地文件夹为素材库目录，再扫描并展示文本、图片、视频和音频文件。" />
                    </StackPanel>

                    <Grid ColumnDefinitions="Auto,Auto,*" ColumnSpacing="10">
                        <Button Classes="primary" Click="AddLibraryFolder_Click" Content="添加素材库目录" />
                        <Button Grid.Column="1" Classes="secondary" Command="{Binding ScanSelectedLibraryCommand}" Content="扫描当前素材库" />
                    </Grid>

                    <Border Classes="soft-surface">
                        <StackPanel Spacing="10">
                            <TextBlock FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppTextBrush}"
                                       Text="{Binding SelectedLibrary.Name, FallbackValue=尚未选择素材库}" />
                            <TextBlock Classes="section-subtitle"
                                       Text="{Binding SelectedLibrary.RootPath, FallbackValue=请先添加一个素材库目录。}" />
                            <TextBlock Foreground="{DynamicResource AppMutedTextBrush}"
                                       TextWrapping="Wrap"
                                       Text="{Binding SelectedLibrary.Summary, FallbackValue=树状视图会按素材库、目录和文件展示扫描结果。}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Classes="surface">
                <Grid RowDefinitions="Auto,Auto,*" RowSpacing="16">
                    <StackPanel Spacing="4">
                        <TextBlock Classes="eyebrow" Text="Asset Queue" />
                        <TextBlock Classes="section-title" Text="{Binding WorkspaceTitle}" />
                        <TextBlock Classes="section-subtitle" Text="{Binding WorkspaceSummary}" />
                    </StackPanel>

                    <Border Grid.Row="1" Classes="soft-surface">
                        <TextBlock Foreground="{DynamicResource AppMutedTextBrush}" TextWrapping="Wrap" Text="{Binding AssetSummary}" />
                    </Border>

                    <TreeView Grid.Row="2"
                              Classes="asset-tree"
                              AutoScrollToSelectedItem="True"
                              ItemsSource="{Binding AssetTreeRoots}"
                              SelectedItem="{Binding SelectedAssetTreeNode, Mode=TwoWay}">
                        <TreeView.ItemTemplate>
                            <TreeDataTemplate x:DataType="models:AssetLibraryTreeNode"
                                              ItemsSource="{Binding Children}">
                                <Border Classes="tree-node-surface">
                                    <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto" ColumnSpacing="8">
                                        <Border Width="22"
                                                Height="22"
                                                Background="{DynamicResource AppBadgeBrush}"
                                                CornerRadius="999"
                                                VerticalAlignment="Center">
                                            <lucide:LucideIcon HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               Size="14"
                                                               Kind="FolderTree" />
                                        </Border>
                                        <TextBlock Grid.Column="1"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   Foreground="{DynamicResource AppTextBrush}"
                                                   Text="{Binding DisplayName}" />
                                        <TextBlock Grid.Column="2"
                                                   FontSize="11"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource AppSecondaryTextBrush}"
                                                   Text="{Binding MetaLabel}" />
                                        <Border Grid.Column="3"
                                                Background="{DynamicResource AppBadgeBrush}"
                                                CornerRadius="999"
                                                Padding="8,3"
                                                HorizontalAlignment="Right">
                                            <TextBlock FontSize="11"
                                                       Foreground="{DynamicResource AppAccentBrush}"
                                                       Text="{Binding CategorySummary}" />
                                        </Border>
                                        <TextBlock Grid.Column="4"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource AppSecondaryTextBrush}"
                                                   Text="{Binding StatusLabel}" />
                                    </Grid>
                                </Border>
                            </TreeDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
