<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AssetsLibrarySystem.Avalonia.ViewModels"
             xmlns:pagevm="using:AssetsLibrarySystem.Avalonia.ViewModels"
             xmlns:models="using:AssetsLibrarySystem.Avalonia.Models"
             xmlns:lucide="clr-namespace:Lucide.Avalonia;assembly=Lucide.Avalonia"
             x:Class="AssetsLibrarySystem.Avalonia.Views.Pages.LibraryPage"
             x:DataType="pagevm:LibraryPageViewModel">
    <Design.DataContext>
        <pagevm:LibraryPageViewModel />
    </Design.DataContext>

    <UserControl.Styles>
        <Style Selector="Border.page-card">
            <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12" />
        </Style>
        <Style Selector="Border.sub-card">
            <Setter Property="Background" Value="{DynamicResource AppSoftSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="8" />
        </Style>
        <Style Selector="Button.primary-action">
            <Setter Property="Background" Value="{DynamicResource AppAccentBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="MinHeight" Value="32" />
        </Style>
        <Style Selector="Button.secondary-action">
            <Setter Property="Background" Value="{DynamicResource AppSoftSurfaceBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="MinHeight" Value="32" />
        </Style>
        <Style Selector="Button.result-action">
            <Setter Property="Background" Value="{DynamicResource AppSoftSurfaceBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
        </Style>
        <Style Selector="TextBlock.eyebrow">
            <Setter Property="Foreground" Value="{DynamicResource AppSecondaryTextBrush}" />
            <Setter Property="FontSize" Value="9" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="LetterSpacing" Value="1.2" />
        </Style>
        <Style Selector="TextBlock.section-title">
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="TextBlock.section-subtitle">
            <Setter Property="Foreground" Value="{DynamicResource AppSecondaryTextBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style Selector="TextBox.compact-input">
            <Setter Property="Background" Value="{DynamicResource AppSoftSurfaceBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="MinHeight" Value="32" />
        </Style>
    </UserControl.Styles>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid RowDefinitions="Auto,*" RowSpacing="8">
            <Border Classes="page-card">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <StackPanel Spacing="4">
                        <TextBlock Classes="eyebrow" Text="素材库" />
                        <TextBlock Classes="section-title" Text="目录与定位" />
                        <TextBlock Classes="section-subtitle"
                                   Text="左侧浏览目录树，右侧查看当前素材与描述结果。" />
                    </StackPanel>

                    <!-- <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center"> -->
                    <!--     <TextBlock Classes="eyebrow" Text="后端状态" /> -->
                    <!--     <TextBlock Foreground="{DynamicResource AppTextBrush}" -->
                    <!--                FontWeight="SemiBold" -->
                    <!--                Text="{Binding BackendStatusTitle}" /> -->
                    <!--     <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}" -->
                    <!--                Text="{Binding BackendStatusStage}" /> -->
                    <!-- </StackPanel> -->
                </Grid>
            </Border>

            <Grid Grid.Row="1" ColumnDefinitions="300,*" ColumnSpacing="8">
                <StackPanel Spacing="8">
                    <Border Classes="page-card">
                        <StackPanel Spacing="8">
                            <TextBlock Classes="eyebrow" Text="素材库" />
                            <TextBlock Classes="section-title" Text="{Binding SelectedLibrary.Name, FallbackValue=未选择}" />
                            <TextBlock Classes="section-subtitle"
                                       Text="{Binding SelectedLibrary.Summary, FallbackValue=尚未加载素材库。}" />
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="4">
                                <Button Classes="primary-action"
                                        Click="AddLibraryFolder_Click"
                                        Content="添加目录" />
                                <Button Grid.Column="1"
                                        Classes="secondary-action"
                                        Command="{Binding ScanSelectedLibraryCommand}"
                                        Content="扫描当前" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Classes="page-card">
                        <Grid RowDefinitions="Auto,*" RowSpacing="8">
                            <StackPanel Spacing="4">
                                <TextBlock Classes="eyebrow" Text="目录树" />
                                <TextBlock Classes="section-title" Text="当前素材库结构" />
                            </StackPanel>

                            <ScrollViewer Grid.Row="1"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Auto">
                                <TreeView Classes="tree-root"
                                          AutoScrollToSelectedItem="True"

                                          ItemsSource="{Binding AssetTreeRoots}"
                                          SelectedItem="{Binding SelectedAssetTreeNode, Mode=TwoWay}">
                                    <TreeView.Styles>
                                        <Style
                                            Selector="TreeViewItem:selected /template/ Border#PART_LayoutRoot">
                                            <Setter Property="Background" Value="Transparent" />
                                        </Style>
                                        <Style
                                            Selector="TreeViewItem:pointerover /template/ Border#PART_LayoutRoot">
                                            <Setter Property="Background" Value="Transparent" />
                                        </Style>

                                        <Style Selector="Border.tree-item">
                                            <Setter Property="Background" Value="{DynamicResource AppSoftSurfaceBrush}" />
                                            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
                                            <Setter Property="BorderThickness" Value="1" />
                                            <Setter Property="CornerRadius" Value="4" />
                                            <Setter Property="Padding" Value="8" />
                                        </Style>
                                    </TreeView.Styles>
                                    <TreeView.ItemTemplate>
                                        <TreeDataTemplate x:DataType="models:AssetLibraryTreeNode"
                                                          ItemsSource="{Binding Children}">
                                            <Border Classes="tree-item">
                                                <Border.ContextMenu>
                                                    <ContextMenu>
                                                        <MenuItem Header="在文件资源管理器中显示"
                                                                  Click="RevealInExplorer_Click"
                                                                  CommandParameter="{Binding}" />
                                                    </ContextMenu>
                                                </Border.ContextMenu>
                                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                                                    <Border Background="{DynamicResource AppAccentSurfaceBrush}"
                                                            BorderBrush="{DynamicResource AppAccentBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="4"
                                                            Width="20"
                                                            Height="20">
                                                        <lucide:LucideIcon Kind="Folder" Size="12" />
                                                    </Border>
                                                    <StackPanel Grid.Column="1" Spacing="2">
                                                        <TextBlock Foreground="{DynamicResource AppTextBrush}"
                                                                   FontWeight="SemiBold"
                                                                   Text="{Binding DisplayName}" />
                                                        <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                                                   Text="{Binding PathLabel}" />
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="2"
                                                               Foreground="{DynamicResource AppAccentBrush}"
                                                               VerticalAlignment="Center"
                                                               Text="{Binding MetaLabel}" />
                                                </Grid>
                                            </Border>
                                        </TreeDataTemplate>
                                    </TreeView.ItemTemplate>
                                </TreeView>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </StackPanel>

                <Grid Grid.Column="1" RowDefinitions="Auto,Auto,Auto" RowSpacing="8">
                    <Border Classes="page-card">
                        <StackPanel Spacing="8">
                            <TextBlock Classes="eyebrow" Text="已选素材" />
                            <TextBlock Classes="section-title" Text="{Binding SelectedAssetName}" />
                            <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                       Text="{Binding SelectedAssetLibrary}" />
                            <TextBlock Classes="section-subtitle" Text="{Binding SelectedAssetPath}" />

                            <Grid ColumnDefinitions="*,*" ColumnSpacing="4" RowDefinitions="Auto,Auto" RowSpacing="4">
                                <Border Classes="sub-card">
                                    <StackPanel Spacing="2">
                                        <TextBlock Classes="eyebrow" Text="类型" />
                                        <TextBlock Foreground="{DynamicResource AppTextBrush}"
                                                   Text="{Binding SelectedAssetType}" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" Classes="sub-card">
                                    <StackPanel Spacing="2">
                                        <TextBlock Classes="eyebrow" Text="阶段" />
                                        <TextBlock Foreground="{DynamicResource AppTextBrush}"
                                                   Text="{Binding SelectedAssetStage}" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Row="1" Grid.ColumnSpan="2" Classes="sub-card">
                                    <StackPanel Spacing="2">
                                        <TextBlock Classes="eyebrow" Text="状态" />
                                        <TextBlock Foreground="{DynamicResource AppTextBrush}"
                                                   Text="{Binding SelectedAssetAiState}" />
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <Border Classes="sub-card">
                                <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                           TextWrapping="Wrap"
                                           Text="{Binding SelectedAssetDetail}" />
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" Classes="page-card">
                        <StackPanel Spacing="8">
                            <TextBlock Classes="eyebrow" Text="描述详情" />
                            <TextBlock Classes="section-title" Text="本地 SQLite 中的描述记录" />
                            <TextBlock Foreground="{DynamicResource AppTextBrush}"
                                       TextWrapping="Wrap"
                                       Text="{Binding SelectedAssetDescriptionState}" />
                            <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                       TextWrapping="Wrap"
                                       Text="{Binding SelectedAssetDescriptionGeneratedAt, StringFormat=生成时间：{0}}" />
                            <Border Classes="sub-card">
                                <TextBlock Foreground="{DynamicResource AppTextBrush}"
                                           TextWrapping="Wrap"
                                           Text="{Binding SelectedAssetDescriptionText}" />
                            </Border>
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="4">
                                <Border Classes="sub-card">
                                    <StackPanel Spacing="2">
                                        <TextBlock Classes="eyebrow" Text="存储" />
                                        <TextBlock Foreground="{DynamicResource AppTextBrush}"
                                                   TextWrapping="Wrap"
                                                   Text="{Binding SelectedAssetDescriptionStorePath}" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" Classes="sub-card">
                                    <StackPanel Spacing="2">
                                        <TextBlock Classes="eyebrow" Text="模式" />
                                        <TextBlock Foreground="{DynamicResource AppTextBrush}"
                                                   Text="{Binding SelectedAssetDescriptionMode}" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                            <Border Classes="sub-card">
                                <StackPanel Spacing="2">
                                    <TextBlock Classes="eyebrow" Text="Token 用量" />
                                    <TextBlock Foreground="{DynamicResource AppTextBrush}"
                                               TextWrapping="Wrap"
                                               Text="{Binding SelectedAssetDescriptionTokenUsage}" />
                                </StackPanel>
                            </Border>
                            <Border Classes="sub-card">
                                <StackPanel Spacing="4">
                                    <TextBlock Classes="eyebrow" Text="提示词" />
                                    <TextBlock Foreground="{DynamicResource AppTextBrush}"
                                               TextWrapping="Wrap"
                                               Text="{Binding SelectedAssetDescriptionPrompt}" />
                                    <TextBlock Classes="eyebrow" Text="系统提示词" />
                                    <TextBlock Foreground="{DynamicResource AppTextBrush}"
                                               TextWrapping="Wrap"
                                               Text="{Binding SelectedAssetDescriptionSystemPrompt}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="2" Classes="page-card">
                        <StackPanel Spacing="8">
                            <TextBlock Classes="eyebrow" Text="动态" />
                            <TextBlock Classes="section-title" Text="活动纪要" />
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Height="240">
                                <ItemsControl ItemsSource="{Binding ActivityFeed}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Classes="sub-card" Margin="0,0,0,4">
                                                <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                                           TextWrapping="Wrap"
                                                           Text="{Binding .}" />
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
