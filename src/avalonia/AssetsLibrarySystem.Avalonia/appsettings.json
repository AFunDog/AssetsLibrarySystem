{
  "Runtime": {
    "DataRoot": ""
  },
  "SearchModels": {
    "EmbeddingProvider": "dashscope",
    "EmbeddingModel": "text-embedding-v4",
    "EmbeddingDimensions": 1024,
    "EmbeddingModels": {
      "DashScope": {
        "Model": "text-embedding-v4",
        "Dimensions": 1024
      },
      "Local": {
        "Model": "Qwen/Qwen3-Embedding-0.6B",
        "Dimensions": 1024
      }
    },
    "RerankProvider": "dashscope",
    "RerankModel": "qwen3-rerank",
    "RerankModels": {
      "DashScope": {
        "Model": "qwen3-rerank"
      },
      "Local": {
        "Model": "Qwen/Qwen3-Reranker-0.6B"
      }
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Verbose",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [ "FromLogContext" ],
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "restrictedToMinimumLevel": "Information"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/avalonia-.log",
          "restrictedToMinimumLevel": "Verbose",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "shared": true
        }
      }
    ]
  },
  "BackendLauncher": {
    "DebugPythonPath": ".venv\\Scripts\\python.exe",
    "DebugArgumentsTemplate": "-m uvicorn app.main:app --host {host} --port {port}",
    "PublishedExecutablePath": "assets-library-system-backend.exe",
    "PublishedArgumentsTemplate": "--host {host} --port {port}",
    "BackendWorkingDirectory": "",
    "Host": "127.0.0.1",
    "Port": 8000,
    "StartupTimeoutSeconds": 30,
    "HealthCheckIntervalMilliseconds": 500,
    "HeartbeatIntervalSeconds": 2,
    "HeartbeatTimeoutSeconds": 8,
    "HeartbeatStartupGraceSeconds": 15
  }
}
