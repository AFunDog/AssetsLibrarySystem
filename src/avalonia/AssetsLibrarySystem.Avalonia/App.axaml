<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AssetsLibrarySystem.Avalonia.ViewModels"
             x:Class="AssetsLibrarySystem.Avalonia.App"
             x:DataType="vm:DesktopShellViewModel"
             RequestedThemeVariant="Dark">
    <Application.Styles>
        <FluentTheme />
    </Application.Styles>

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="AppAccentBrush"
                                     Color="{DynamicResource SystemAccentColor}" />

                    <SolidColorBrush x:Key="AppAccentHoverBrush"
                                     Color="{DynamicResource SystemAccentColorLight1}" />

                    <SolidColorBrush x:Key="AppAccentPressedBrush"
                                     Color="{DynamicResource SystemAccentColorDark1}" />

                    <SolidColorBrush x:Key="AppAccentSurfaceBrush"
                                     Color="{DynamicResource SystemAccentColor}"
                                     Opacity="0.12" />

                    <!-- Windows 11 base/content layering -->
                    <SolidColorBrush x:Key="AppWindowBackgroundBrush" Color="#F3F3F3" />
                    <SolidColorBrush x:Key="AppSurfaceBrush" Color="#FFFFFF" />
                    <SolidColorBrush x:Key="AppSoftSurfaceBrush" Color="#F9F9F9" />

                    <!-- 中性边框 -->
                    <SolidColorBrush x:Key="AppBorderBrush" Color="#E5E5E5" />

                    <!-- 中性文字 -->
                    <SolidColorBrush x:Key="AppTextBrush" Color="#111111" />
                    <SolidColorBrush x:Key="AppSecondaryTextBrush" Color="#666666" />
                    <SolidColorBrush x:Key="AppMutedTextBrush" Color="#444444" />

                    <!-- 徽章/标签背景 -->
                    <SolidColorBrush x:Key="AppBadgeBrush" Color="#EEEEEE" />
                </ResourceDictionary>

                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="AppAccentBrush"
                                     Color="{DynamicResource SystemAccentColor}" />

                    <SolidColorBrush x:Key="AppAccentHoverBrush"
                                     Color="{DynamicResource SystemAccentColorLight1}" />

                    <SolidColorBrush x:Key="AppAccentPressedBrush"
                                     Color="{DynamicResource SystemAccentColorDark1}" />

                    <SolidColorBrush x:Key="AppAccentSurfaceBrush"
                                     Color="{DynamicResource SystemAccentColor}"
                                     Opacity="0.14" />

                    <!-- Windows 11 base/content layering -->
                    <SolidColorBrush x:Key="AppWindowBackgroundBrush" Color="#1F1F1F" />
                    <SolidColorBrush x:Key="AppSurfaceBrush" Color="#242424" />
                    <SolidColorBrush x:Key="AppSoftSurfaceBrush" Color="#2B2B2B" />

                    <!-- 中性边框 -->
                    <SolidColorBrush x:Key="AppBorderBrush" Color="#383838" />

                    <!-- 中性文字 -->
                    <SolidColorBrush x:Key="AppTextBrush" Color="#F2F2F2" />
                    <SolidColorBrush x:Key="AppSecondaryTextBrush" Color="#B8B8B8" />
                    <SolidColorBrush x:Key="AppMutedTextBrush" Color="#D0D0D0" />

                    <!-- 徽章/标签背景 -->
                    <SolidColorBrush x:Key="AppBadgeBrush" Color="#242424" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Application.Resources>

    <TrayIcon.Icons>
        <TrayIcons>
            <TrayIcon Icon="/Assets/avalonia-logo.ico"
                      ToolTipText="{Binding TrayTitle}"
                      Command="{Binding ToggleQuickSearchWindowCommand}">
                <TrayIcon.Menu>
                    <NativeMenu>
                        <NativeMenuItem Header="{Binding TrayTitle}"
                                        IsEnabled="False" />
                        <NativeMenuItem Header="{Binding TrayStatusTitle}"
                                        IsEnabled="False" />
                        <NativeMenuItem Header="{Binding TrayStatusDetail}"
                                        IsEnabled="False" />
                        <NativeMenuItem Header="{Binding TrayHotkeyHint}"
                                        IsEnabled="False" />
                        <NativeMenuItem Header="{Binding TrayActionHint}"
                                        IsEnabled="False" />
                        <NativeMenuItemSeparator />
                        <NativeMenuItem Header="打开快速检索"
                                        Command="{Binding ShowQuickSearchWindowCommand}" />
                        <NativeMenuItem Header="打开主窗口"
                                        Command="{Binding ShowMainWindowCommand}" />
                        <NativeMenuItemSeparator />
                        <NativeMenuItem Header="退出"
                                        Command="{Binding ExitApplicationCommand}" />
                    </NativeMenu>
                </TrayIcon.Menu>
            </TrayIcon>
        </TrayIcons>
    </TrayIcon.Icons>
</Application>
