<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AssetsLibrarySystem.Avalonia.ViewModels"
             x:Class="AssetsLibrarySystem.Avalonia.App"
             x:DataType="vm:DesktopShellViewModel"
             RequestedThemeVariant="Dark">
    <Application.Styles>
        <FluentTheme />
    </Application.Styles>

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="AppAccentBrush" Color="{DynamicResource SystemAccentColor}" />
                    <SolidColorBrush x:Key="AppAccentSurfaceBrush" Color="{DynamicResource SystemAccentColor}" Opacity="0.12" />
                    <SolidColorBrush x:Key="AppWindowBackgroundBrush" Color="#EEF3F9" />
                    <SolidColorBrush x:Key="AppSurfaceBrush" Color="#FCFEFF" />
                    <SolidColorBrush x:Key="AppSoftSurfaceBrush" Color="#F7FAFD" />
                    <SolidColorBrush x:Key="AppBorderBrush" Color="#DDE5EF" />
                    <SolidColorBrush x:Key="AppTextBrush" Color="#141B24" />
                    <SolidColorBrush x:Key="AppSecondaryTextBrush" Color="#5B6B7E" />
                    <SolidColorBrush x:Key="AppMutedTextBrush" Color="#314155" />
                    <SolidColorBrush x:Key="AppBadgeBrush" Color="#EDF3FA" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="AppAccentBrush" Color="{DynamicResource SystemAccentColor}" />
                    <SolidColorBrush x:Key="AppAccentSurfaceBrush" Color="{DynamicResource SystemAccentColor}" Opacity="0.14" />
                    <SolidColorBrush x:Key="AppWindowBackgroundBrush" Color="#0D1117" />
                    <SolidColorBrush x:Key="AppSurfaceBrush" Color="#131922" />
                    <SolidColorBrush x:Key="AppSoftSurfaceBrush" Color="#171E28" />
                    <SolidColorBrush x:Key="AppBorderBrush" Color="#243140" />
                    <SolidColorBrush x:Key="AppTextBrush" Color="#E9EEF5" />
                    <SolidColorBrush x:Key="AppSecondaryTextBrush" Color="#9FA9B6" />
                    <SolidColorBrush x:Key="AppMutedTextBrush" Color="#C7D0D9" />
                    <SolidColorBrush x:Key="AppBadgeBrush" Color="#1A222C" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Application.Resources>

    <TrayIcon.Icons>
        <TrayIcons>
            <TrayIcon Icon="/Assets/avalonia-logo.ico"
                      ToolTipText="{Binding TrayTitle}"
                      Command="{Binding ToggleQuickSearchWindowCommand}">
                <TrayIcon.Menu>
                    <NativeMenu>
                        <NativeMenuItem Header="{Binding TrayTitle}"
                                        IsEnabled="False" />
                        <NativeMenuItem Header="{Binding TrayStatusTitle}"
                                        IsEnabled="False" />
                        <NativeMenuItem Header="{Binding TrayStatusDetail}"
                                        IsEnabled="False" />
                        <NativeMenuItem Header="{Binding TrayHotkeyHint}"
                                        IsEnabled="False" />
                        <NativeMenuItem Header="{Binding TrayActionHint}"
                                        IsEnabled="False" />
                        <NativeMenuItemSeparator />
                        <NativeMenuItem Header="打开快速检索"
                                        Command="{Binding ShowQuickSearchWindowCommand}" />
                        <NativeMenuItem Header="打开主窗口"
                                        Command="{Binding ShowMainWindowCommand}" />
                        <NativeMenuItemSeparator />
                        <NativeMenuItem Header="退出"
                                        Command="{Binding ExitApplicationCommand}" />
                    </NativeMenu>
                </TrayIcon.Menu>
            </TrayIcon>
        </TrayIcons>
    </TrayIcon.Icons>
</Application>
